<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Resistance City — Свободный Город. Minecraft RolePlay проект с демократическим управлением, экономикой и карьерой.">
    <meta name="keywords" content="Minecraft, RolePlay, Resistance, клан, экономика, RP, город, свободный, демократия">
    <meta name="theme-color" content="#6343d4">
    <meta name="color-scheme" content="dark">
    <meta property="og:title" content="Resistance City — Свободный Город">
    <meta property="og:description" content="Minecraft RolePlay проект с уникальной экономикой и системой государственного управления">
    <meta property="og:type" content="website">
    <title><%= typeof title !== 'undefined' ? title : 'Resistance City — Свободный Город' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
    <style>
        .hero-section {
            background: linear-gradient(135deg, rgba(99,67,212,0.3) 0%, rgba(22,22,42,0.95) 50%, rgba(170,78,255,0.2) 100%);
            padding: 80px 24px 100px;
            text-align: center;
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid var(--border);
        }
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 30% 50%, rgba(99,67,212,0.2) 0%, transparent 50%),
                radial-gradient(circle at 70% 50%, rgba(170,78,255,0.15) 0%, transparent 50%),
                radial-gradient(circle at 50% 80%, rgba(255,184,0,0.05) 0%, transparent 40%);
            z-index: 0;
        }
        .hero-content {
            position: relative;
            z-index: 1;
        }
        .member-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 10px;
            background: rgba(255,255,255,0.02);
            margin-bottom: 8px;
            transition: all 0.2s ease;
        }
        .member-card:hover {
            background: rgba(99,67,212,0.08);
        }
        .member-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-lighter));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .top-player-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 14px;
            border-radius: 10px;
            background: rgba(255,255,255,0.02);
            margin-bottom: 8px;
            transition: all 0.2s ease;
        }
        .top-player-row:hover {
            background: rgba(99,67,212,0.08);
        }
        .org-card {
            text-align: left;
        }
        .feature-card {
            text-align: center;
            padding: 32px 20px;
        }
        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
        }
        .cta-section {
            text-align: center;
            padding: 48px 32px;
            background: linear-gradient(135deg, rgba(99,67,212,0.2), rgba(170,78,255,0.1));
            border-color: var(--primary);
            margin-bottom: 40px;
        }
    </style>
</head>
<body>
    <%- include('partials/header', { page: 'home' }) %>

    <!-- ==================== HERO ==================== -->
    <section class="hero-section">
        <div class="container hero-content">
            <div style="margin-bottom: 16px;">
                <span class="badge badge-info" style="font-size: 0.9rem; padding: 6px 16px;">Minecraft Java Edition 1.20.4</span>
                <span class="badge badge-success" style="font-size: 0.9rem; padding: 6px 16px; margin-left: 8px;">RolePlay</span>
                <span class="badge badge-warning" style="font-size: 0.9rem; padding: 6px 16px; margin-left: 8px;">Демократия</span>
            </div>
            
            <h1 class="text-gradient" style="font-size: 3.5rem; margin-bottom: 4px; line-height: 1.2; font-weight: 800;">
                <%= typeof clanName !== 'undefined' ? clanName : 'Resistance' %>
            </h1>
            <p style="font-size: 1.4rem; color: var(--text-secondary); margin-bottom: 8px; font-weight: 300;">
                Свободный Город «Сопротивление»
            </p>
            <p style="font-size: 1.1rem; color: var(--text-muted); max-width: 700px; margin: 0 auto 32px; line-height: 1.8;">
                Уникальный Minecraft RolePlay проект с демократической формой правления,<br>
                живой экономикой, конституцией и развитой системой государственных структур.<br>
                Станьте частью города, где каждый голос имеет значение.
            </p>
            
            <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 24px;">
                <a href="/career" class="btn btn-primary btn-lg" style="min-width: 220px;">
                    🏛️ Государственные структуры
                </a>
                <a href="/top" class="btn btn-outline btn-lg" style="min-width: 180px;">
                    🏆 Рейтинг игроков
                </a>
                <a href="/properties" class="btn btn-outline btn-lg" style="min-width: 200px;">
                    🏠 Рынок недвижимости
                </a>
            </div>
            
            <div style="color: var(--text-muted); font-size: 0.95rem;">
                IP сервера: 
                <code style="background: rgba(255,255,255,0.05); padding: 6px 14px; border-radius: 6px; color: var(--info); font-size: 1rem; letter-spacing: 1px;">
                    ru.dexland.org
                </code>
            </div>
        </div>
    </section>

    <div class="container" style="margin-top: -50px; position: relative; z-index: 2;">

        <!-- ==================== СТАТИСТИКА ==================== -->
        <div class="grid grid-4" style="margin-bottom: 40px;">
            <div class="stat-card card-glow">
                <div class="stat-icon">👥</div>
                <div class="stat-value"><%= typeof stats !== 'undefined' && stats ? stats.rpCount : 0 %></div>
                <div class="stat-label">Участников RolePlay</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">активных граждан</div>
            </div>
            <div class="stat-card card-glow">
                <div class="stat-icon">⚔️</div>
                <div class="stat-value"><%= typeof stats !== 'undefined' && stats ? stats.clanCount : 0 %></div>
                <div class="stat-label">В клане Resistance</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">членов клана</div>
            </div>
            <div class="stat-card card-glow">
                <div class="stat-icon">🟢</div>
                <div class="stat-value"><%= typeof stats !== 'undefined' && stats ? stats.onlineCount : 0 %></div>
                <div class="stat-label">В городе сейчас</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">на дежурстве / на связи</div>
            </div>
            <div class="stat-card card-glow">
                <div class="stat-icon">💰</div>
                <div class="stat-value">
                    <% 
                        var totalMoney = (typeof stats !== 'undefined' && stats && stats.totalMoney) ? stats.totalMoney : 0;
                    %>
                    <%= Math.floor(totalMoney / 1000000) %>M
                </div>
                <div class="stat-label">В экономике</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">общий капитал игроков</div>
            </div>
        </div>

        <!-- ==================== НОВЫЕ УЧАСТНИКИ + ТОП БАЛАНС ==================== -->
        <div class="grid grid-2" style="margin-bottom: 40px;">
            
            <!-- Новые участники -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">👋 Новые участники клана</h3>
                    <a href="/top" class="btn btn-sm btn-outline">Все игроки</a>
                </div>
                <div class="card-body">
                    <% if (typeof recentJoins !== 'undefined' && recentJoins && recentJoins.length > 0) { %>
                        <% for (var i = 0; i < recentJoins.length; i++) { 
                            var member = recentJoins[i];
                        %>
                            <div class="member-card">
                                <div class="member-avatar">
                                    <%= member.username ? member.username.charAt(0).toUpperCase() : '?' %>
                                </div>
                                <div style="flex: 1;">
                                    <a href="/profile/<%= member.username %>" style="font-weight: 600; color: var(--text-bright); font-size: 1.05rem;">
                                        <%= member.username %>
                                    </a>
                                    <div style="display: flex; gap: 16px; margin-top: 2px;">
                                        <span style="font-size: 0.8rem; color: var(--text-muted);">
                                            📅 <%= member.joined_at ? new Date(member.joined_at).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }) : '—' %>
                                        </span>
                                        <% if (member.kills && member.kills > 0) { %>
                                            <span style="font-size: 0.8rem; color: var(--danger);">
                                                ⚔ <%= member.kills %> убийств
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                                <a href="/profile/<%= member.username %>" style="color: var(--text-muted); text-decoration: none; font-size: 1.2rem;" title="Профиль">→</a>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div style="text-align: center; padding: 30px 20px; color: var(--text-muted);">
                            <div style="font-size: 2rem; margin-bottom: 8px;">📭</div>
                            <p>Пока нет новых участников</p>
                            <p style="font-size: 0.85rem;">Станьте первым! Присоединяйтесь к Resistance.</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Топ-5 по балансу -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">💰 Богатейшие граждане</h3>
                    <a href="/top?type=balance" class="btn btn-sm btn-outline">Полный топ</a>
                </div>
                <div class="card-body">
                    <% if (typeof topBalance !== 'undefined' && topBalance && topBalance.length > 0) { %>
                        <% for (var j = 0; j < topBalance.length; j++) { 
                            var player = topBalance[j];
                            var medal = j === 0 ? '🥇' : j === 1 ? '🥈' : j === 2 ? '🥉' : (j + 1);
                        %>
                            <div class="top-player-row">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <span style="font-weight: 700; font-size: 1.2rem; min-width: 36px; text-align: center; color: var(--primary-lighter);">
                                        <%= medal %>
                                    </span>
                                    <div style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, rgba(99,67,212,0.3), rgba(170,78,255,0.2)); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--text-bright); flex-shrink: 0;">
                                        <%= player.username ? player.username.charAt(0).toUpperCase() : '?' %>
                                    </div>
                                    <a href="/profile/<%= player.username %>" style="font-weight: 600; color: var(--text-bright);">
                                        <%= player.username %>
                                    </a>
                                </div>
                                <div style="text-align: right;">
                                    <span style="font-weight: 700; color: var(--success); font-size: 1.05rem;">
                                        <%= (player.balance || 0).toLocaleString() %> ₽
                                    </span>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">наличные</div>
                                </div>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div style="text-align: center; padding: 30px 20px; color: var(--text-muted);">
                            <div style="font-size: 2rem; margin-bottom: 8px;">💸</div>
                            <p>Нет данных о балансе</p>
                            <p style="font-size: 0.85rem;">Экономика города ждёт вас!</p>
                        </div>
                    <% } %>
                </div>
                <% if (typeof topBalance !== 'undefined' && topBalance && topBalance.length >= 5) { 
                    var totalTopBalance = 0;
                    for (var k = 0; k < topBalance.length; k++) {
                        totalTopBalance += (topBalance[k].balance || 0);
                    }
                %>
                    <div class="card-footer" style="text-align: center;">
                        <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">
                            Общий капитал топ-5: <strong style="color: var(--success);"><%= totalTopBalance.toLocaleString() %> ₽</strong>
                        </p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ==================== ОРГАНИЗАЦИИ ==================== -->
        <div style="margin-bottom: 40px;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
                <div>
                    <h2 class="text-gradient" style="margin-bottom: 4px;">🏛️ Государственные структуры</h2>
                    <p style="color: var(--text-secondary);">Основа Resistance — система государственного управления</p>
                </div>
                <a href="/career" class="btn btn-outline">Подробнее о карьере →</a>
            </div>
            <div class="grid grid-3">
                <% if (typeof organizations !== 'undefined' && organizations && organizations.length > 0) { %>
                    <% for (var o = 0; o < organizations.length; o++) { 
                        var org = organizations[o];
                        var orgIcons = {
                            'police': '🚔',
                            'army': '🛡️',
                            'hospital': '🏥',
                            'academy': '🎓',
                            'government': '🏛️'
                        };
                        var orgIcon = orgIcons[org.key] || '📌';
                        
                        // Заранее вычисляем стиль
                        var orgCardStyle = '';
                        if (org.isFrozen) {
                            orgCardStyle = 'opacity: 0.6; border-color: var(--danger);';
                        }
                    %>
                        <div class="card card-glow org-card"<%- org.isFrozen ? ' style="opacity: 0.6; border-color: var(--danger);"' : '' %>>
                            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                                <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, var(--primary), var(--primary-lighter)); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                                    <%= orgIcon %>
                                </div>
                                <div>
                                    <h4 style="margin-bottom: 0px;"><%= org.name %></h4>
                                    <% if (org.isFrozen) { %>
                                        <span class="badge badge-danger">Заморожена</span>
                                    <% } %>
                                </div>
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="color: var(--text-secondary); font-size: 0.9rem;">Сотрудников</span>
                                    <span style="font-weight: 600; color: var(--info); font-size: 1.1rem;"><%= org.employees %></span>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="color: var(--text-secondary); font-size: 0.9rem;">Бюджет</span>
                                    <span style="font-weight: 600; color: var(--success); font-size: 1.1rem;">
                                        <%= org.budget >= 1000000 ? (org.budget / 1000000).toFixed(1) + 'M' : Math.floor(org.budget / 1000) + 'K' %> ₽
                                    </span>
                                </div>
                            </div>
                            <a href="/career" class="btn btn-sm btn-outline" style="width: 100%;">Подробнее</a>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="card" style="text-align: center; grid-column: 1 / -1;">
                        <p style="color: var(--text-muted); padding: 20px;">Нет данных об организациях</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ==================== ТОП-5 УБИЙСТВ ==================== -->
        <div class="card" style="margin-bottom: 40px;">
            <div class="card-header">
                <h3 class="card-title">⚔️ Лучшие воины Resistance</h3>
                <a href="/top?type=kills" class="btn btn-sm btn-outline">Полный рейтинг</a>
            </div>
            <div class="card-body">
                <% if (typeof topKills !== 'undefined' && topKills && topKills.length > 0) { %>
                    <div class="grid grid-5">
                        <% for (var w = 0; w < topKills.length; w++) { 
                            var warrior = topKills[w];
                            var warMedal = w === 0 ? '🥇' : w === 1 ? '🥈' : w === 2 ? '🥉' : '🎯';
                        %>
                            <div style="text-align: center; padding: 20px 10px; border-radius: 12px; transition: all 0.2s ease;">
                                <div style="font-size: 2rem; margin-bottom: 8px;"><%= warMedal %></div>
                                <a href="/profile/<%= warrior.username %>" style="font-weight: 600; color: var(--text-bright); display: block; margin-bottom: 8px;">
                                    <%= warrior.username %>
                                </a>
                                <div style="font-weight: 700; color: var(--danger); font-size: 1.4rem;"><%= warrior.kills || 0 %></div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;">убийств</div>
                                <% if (warrior.deaths && warrior.deaths > 0) { %>
                                    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">
                                        K/D: <span style="color: var(--info);"><%= (warrior.kills / warrior.deaths).toFixed(2) %></span>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 30px; color: var(--text-muted);">
                        <div style="font-size: 2rem; margin-bottom: 8px;">🕊️</div>
                        <p>Пока нет данных об убийствах</p>
                        <p style="font-size: 0.85rem;">В городе царит мир... пока что.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ==================== ОСОБЕННОСТИ ==================== -->
        <div style="margin-bottom: 40px;">
            <h2 class="text-gradient" style="text-align: center; margin-bottom: 8px;">🌟 Особенности Resistance</h2>
            <p style="text-align: center; color: var(--text-secondary); margin-bottom: 32px;">Что делает наш город уникальным</p>
            <div class="grid grid-3">
                <div class="card card-glow feature-card">
                    <div class="feature-icon">🏛️</div>
                    <h4 style="margin-bottom: 8px;">Демократия</h4>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;">
                        Конституция, выборы, мэр и министры.<br>
                        Каждый гражданин имеет право голоса<br>
                        и может влиять на жизнь города.
                    </p>
                </div>
                <div class="card card-glow feature-card">
                    <div class="feature-icon">💰</div>
                    <h4 style="margin-bottom: 8px;">Экономика</h4>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;">
                        Рынок недвижимости, бизнесы,<br>
                        банковская система, кредиты,<br>
                        зарплаты и налоги.
                    </p>
                </div>
                <div class="card card-glow feature-card">
                    <div class="feature-icon">⚖️</div>
                    <h4 style="margin-bottom: 8px;">Законы</h4>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;">
                        Сводный кодекс, полиция,<br>
                        судебная система, тюрьма.<br>
                        Порядок и справедливость.
                    </p>
                </div>
            </div>
        </div>

        <!-- ==================== ДОП. СТАТИСТИКА ==================== -->
        <div class="grid grid-3" style="margin-bottom: 40px;">
            <div class="stat-card">
                <div class="stat-icon">🏠</div>
                <div class="stat-value"><%= typeof stats !== 'undefined' && stats ? stats.propertiesOwned : 0 %></div>
                <div class="stat-label">Объектов недвижимости</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">куплено гражданами</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🔒</div>
                <div class="stat-value" style="color: var(--danger);"><%= typeof stats !== 'undefined' && stats ? stats.jailedCount : 0 %></div>
                <div class="stat-label">В тюрьме</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">отбывают наказание</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📋</div>
                <div class="stat-value"><%= typeof organizations !== 'undefined' && organizations ? organizations.length : 0 %></div>
                <div class="stat-label">Госструктур</div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">для службы и карьеры</div>
            </div>
        </div>

        <!-- ==================== CTA ==================== -->
        <div class="card cta-section">
            <h2 class="text-gradient" style="font-size: 2rem; margin-bottom: 12px;">Готовы стать частью Resistance?</h2>
            <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto 32px; font-size: 1.05rem; line-height: 1.8;">
                Присоединяйтесь к нашему сообществу! Развивайте карьеру в государственных структурах,
                создавайте бизнес, участвуйте в экономике и влияйте на будущее города.
            </p>
            <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
                <a href="#" class="btn btn-primary btn-lg" style="min-width: 200px;">
                    🎮 Играть на сервере
                </a>
                <a href="#" class="btn btn-outline btn-lg" style="min-width: 200px;">
                    💬 Discord сервер
                </a>
                <a href="/career" class="btn btn-outline btn-lg" style="min-width: 200px;">
                    🏛️ Карьера
                </a>
            </div>
            <p style="color: var(--text-muted); margin-top: 20px; font-size: 0.85rem;">
                IP: <code style="background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 4px; color: var(--info);">ru.dexland.org</code>
                • Версия 1.20.4 • Java Edition
            </p>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>