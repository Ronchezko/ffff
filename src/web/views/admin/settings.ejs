<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Настройки' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .setting-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border-radius: 8px;
            background: rgba(255,255,255,0.02);
            margin-bottom: 12px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .setting-info {
            flex: 1;
            min-width: 200px;
        }
        .setting-name {
            font-weight: 600;
            color: var(--text-bright);
            margin-bottom: 2px;
        }
        .setting-desc {
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        .setting-control {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .toast-container {
            position: fixed;
            top: 80px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
    </style>
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'settings' }) %>

        <div class="admin-content">
            <h1 class="text-gradient" style="margin-bottom: 24px;">⚙️ Настройки системы</h1>

            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">🔧 Основные настройки</h3>
                    <button class="btn btn-sm btn-primary" onclick="saveAllSettings()">💾 Сохранить все</button>
                </div>
                <div class="card-body">
                    <% if (typeof settings !== 'undefined' && settings && settings.length > 0) { %>
                        <% for (var i = 0; i < settings.length; i++) { 
                            var setting = settings[i];
                            var isBool = isBooleanSetting(setting.key);
                            var isNum = isNumberSetting(setting.key);
                            var desc = getSettingDescription(setting.key);
                        %>
                            <div class="setting-row">
                                <div class="setting-info">
                                    <div class="setting-name"><%= setting.key %></div>
                                    <div class="setting-desc"><%= desc %></div>
                                </div>
                                <div class="setting-control">
                                    <% if (isBool) { %>
                                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                            <input type="checkbox"
                                                   id="setting_<%= setting.key %>"
                                                   <%= setting.value === 'true' ? 'checked' : '' %>
                                                   onchange="markChanged('<%= setting.key %>', this.checked ? 'true' : 'false')"
                                                   style="width: 20px; height: 20px; accent-color: var(--primary);">
                                            <span style="color: var(--text-secondary); font-size: 0.9rem;" id="setting_label_<%= setting.key %>">
                                                <%= setting.value === 'true' ? 'Включено' : 'Выключено' %>
                                            </span>
                                        </label>
                                    <% } else if (isNum) { %>
                                        <input type="number"
                                               id="setting_<%= setting.key %>"
                                               class="form-input"
                                               style="width: 120px;"
                                               value="<%= setting.value %>"
                                               step="0.01"
                                               min="0"
                                               max="1"
                                               onchange="markChanged('<%= setting.key %>', this.value)">
                                    <% } else { %>
                                        <input type="text"
                                               id="setting_<%= setting.key %>"
                                               class="form-input"
                                               style="width: 200px;"
                                               value="<%= setting.value %>"
                                               onchange="markChanged('<%= setting.key %>', this.value)">
                                    <% } %>
                                    <button type="button"
                                            class="btn btn-sm btn-outline"
                                            onclick="resetSetting('<%= setting.key %>')"
                                            title="Сбросить">↺</button>
                                </div>
                            </div>
                        <% } %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 20px;">Нет настроек</p>
                    <% } %>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">🖥️ Системная информация</h3>
                </div>
                <div class="card-body">
                    <table>
                        <tbody>
                            <tr>
                                <td style="color: var(--text-secondary);">Node.js</td>
                                <td style="font-weight: 600;">node</td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Платформа</td>
                                <td style="font-weight: 600;">linux</td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Версия бота</td>
                                <td style="font-weight: 600; color: var(--primary-lighter);">5.0.0</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        var pendingChanges = {};

        function markChanged(key, value) {
            pendingChanges[key] = value;
            var label = document.getElementById('setting_label_' + key);
            if (label && (value === 'true' || value === 'false')) {
                label.textContent = value === 'true' ? 'Включено' : 'Выключено';
            }
            showToast('Изменение: ' + key, 'info');
        }

        function resetSetting(key) {
            delete pendingChanges[key];
            var el = document.getElementById('setting_' + key);
            if (el) {
                if (el.type === 'checkbox') {
                    el.checked = el.defaultChecked;
                    var label = document.getElementById('setting_label_' + key);
                    if (label) label.textContent = el.checked ? 'Включено' : 'Выключено';
                } else {
                    el.value = el.defaultValue;
                }
            }
            showToast('Сброшено: ' + key, 'warning');
        }

        async function saveAllSettings() {
            if (Object.keys(pendingChanges).length === 0) {
                showToast('Нет изменений', 'warning');
                return;
            }

            var successCount = 0;
            var errorCount = 0;

            for (var key in pendingChanges) {
                if (!pendingChanges.hasOwnProperty(key)) continue;
                try {
                    var response = await fetch('/api/admin/settings', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ key: key, value: pendingChanges[key] }),
                    });
                    var data = await response.json();
                    if (data.success) {
                        successCount++;
                        delete pendingChanges[key];
                    } else {
                        errorCount++;
                    }
                } catch (err) {
                    errorCount++;
                }
            }

            if (errorCount === 0) {
                showToast('Сохранено: ' + successCount, 'success');
            } else {
                showToast('Ошибок: ' + errorCount, 'error');
            }
        }

        function showToast(message, type) {
            var container = document.querySelector('.toast-container');
            if (!container) {
                container = document.createElement('div');
                container.className = 'toast-container';
                document.body.appendChild(container);
            }
            var toast = document.createElement('div');
            toast.className = 'toast toast-' + type;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(function() {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(function() { toast.remove(); }, 300);
            }, 3000);
        }
    </script>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>

<%
function getSettingDescription(key) {
    var descriptions = {
        'auto_mod_enabled': 'Автоматическая модерация чата (спам, флуд)',
        'clan_ad_enabled': 'Реклама клана в чате',
        'chat_ad_enabled': 'Реклама в клановом чате',
        'payday_enabled': 'Начисление зарплат (PayDay)',
        'virus_enabled': 'Система заболеваний',
        'global_freeze': 'Глобальная заморозка всех систем',
        'virus_chance': 'Шанс заражения вирусом (0.0 - 1.0)',
        'economy_tax_rate': 'Ставка налога на имущество',
        'payday_tax_rate': 'Ставка подоходного налога',
        'ip_whitelist_enabled': 'Ограничение доступа по IP',
    };
    return descriptions[key] || '—';
}

function isBooleanSetting(key) {
    return ['auto_mod_enabled', 'clan_ad_enabled', 'chat_ad_enabled', 'payday_enabled', 'virus_enabled', 'global_freeze', 'ip_whitelist_enabled'].indexOf(key) !== -1;
}

function isNumberSetting(key) {
    return ['virus_chance', 'economy_tax_rate', 'payday_tax_rate'].indexOf(key) !== -1;
}
%>