<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Просмотр логов' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .log-tabs {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 24px;
            padding: 12px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }
        .log-tabs a {
            padding: 8px 16px;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-secondary);
            transition: all 0.2s ease;
        }
        .log-tabs a:hover {
            background: rgba(99,67,212,0.1);
            color: var(--text-bright);
            text-decoration: none;
        }
        .log-tabs a.active {
            background: var(--primary);
            color: white;
        }
        .log-table {
            width: 100%;
            border-collapse: collapse;
        }
        .log-table th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
        }
        .log-table td {
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
        }
        .log-table tbody tr:hover {
            background: rgba(99,67,212,0.05);
        }
        .log-empty {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
        }
    </style>
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'logs' }) %>

        <div class="admin-content">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
                <div>
                    <h1 class="text-gradient" style="margin-bottom: 4px;">📋 Просмотр логов</h1>
                    <p style="color: var(--text-secondary);">
                        Всего записей: <strong><%= typeof pagination !== 'undefined' && pagination ? pagination.totalCount : 0 %></strong>
                    </p>
                </div>
            </div>

            <!-- ТАБЫ -->
            <div class="log-tabs">
                <a href="/admin/logs?type=punishments" class="<%= typeof type !== 'undefined' && type === 'punishments' ? 'active' : '' %>">
                    🔨 Наказания
                </a>
                <a href="/admin/logs?type=balance" class="<%= typeof type !== 'undefined' && type === 'balance' ? 'active' : '' %>">
                    💰 Финансы
                </a>
                <a href="/admin/logs?type=chat" class="<%= typeof type !== 'undefined' && type === 'chat' ? 'active' : '' %>">
                    💬 Чат
                </a>
            </div>

            <!-- ТАБЛИЦА -->
            <div class="card">
                <div class="table-container">
                    <% if (typeof type !== 'undefined' && type === 'punishments') { %>
                        <table class="log-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Тип</th>
                                    <th>Игрок</th>
                                    <th>Выдал</th>
                                    <th>Причина</th>
                                    <th>Дата</th>
                                    <th>Истекает</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof logs !== 'undefined' && logs && logs.length > 0) { %>
                                    <% for (var i = 0; i < logs.length; i++) { 
                                        var log = logs[i];
                                        var typeBadgeClass = 'badge-info';
                                        if (log.type === 'blacklist') typeBadgeClass = 'badge-danger';
                                        else if (log.type === 'mute' || log.type === 'pm_mute') typeBadgeClass = 'badge-warning';
                                        else if (log.type === 'kick') typeBadgeClass = 'badge-danger';
                                    %>
                                        <tr>
                                            <td><%= log.id %></td>
                                            <td><span class="badge <%= typeBadgeClass %>"><%= log.type %></span></td>
                                            <td style="font-weight: 600;"><%= log.username %></td>
                                            <td><%= log.issued_by %></td>
                                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= log.reason %>">
                                                <%= log.reason %>
                                            </td>
                                            <td style="white-space: nowrap;"><%= log.issued_at ? new Date(log.issued_at).toLocaleString('ru-RU') : '—' %></td>
                                            <td style="white-space: nowrap;"><%= log.expires_at ? new Date(log.expires_at).toLocaleString('ru-RU') : '—' %></td>
                                            <td>
                                                <% if (log.is_active) { %>
                                                    <span class="badge badge-danger">Активно</span>
                                                <% } else { %>
                                                    <span class="badge badge-success">Снято</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="log-empty">Нет записей о наказаниях</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>

                    <% } else if (typeof type !== 'undefined' && type === 'balance') { %>
                        <table class="log-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Игрок</th>
                                    <th>Тип</th>
                                    <th>Сумма</th>
                                    <th>Баланс до</th>
                                    <th>Баланс после</th>
                                    <th>Причина</th>
                                    <th>Дата</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for (var i = 0; i < logs.length; i++) { 
    var log = logs[i];
    var amountSign = log.amount >= 0 ? '+' : '';
    var isPositive = log.amount >= 0;
%>
    <tr>
        <td><%= log.id %></td>
        <td style="font-weight: 600;"><%= log.username %></td>
        <td><span class="badge badge-info"><%= log.type %></span></td>
        <% if (isPositive) { %>
            <td style="font-weight: 700; color: #76C519;">
                +<%= (log.amount || 0).toLocaleString() %> ₽
            </td>
        <% } else { %>
            <td style="font-weight: 700; color: #CA4E4E;">
                <%= (log.amount || 0).toLocaleString() %> ₽
            </td>
        <% } %>
                                            <td><%= (log.balance_before || 0).toLocaleString() %> ₽</td>
                                            <td><%= (log.balance_after || 0).toLocaleString() %> ₽</td>
                                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= log.reason %>">
                                                <%= log.reason %>
                                            </td>
                                            <td style="white-space: nowrap;"><%= log.created_at ? new Date(log.created_at).toLocaleString('ru-RU') : '—' %></td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="log-empty">Нет финансовых записей</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>

                    <% } else if (typeof type !== 'undefined' && type === 'chat') { %>
                        <table class="log-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Игрок</th>
                                    <th>Сообщение</th>
                                    <th>Дата</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof logs !== 'undefined' && logs && logs.length > 0) { %>
                                    <% for (var i = 0; i < logs.length; i++) { 
                                        var log = logs[i];
                                    %>
                                        <tr>
                                            <td><%= log.id %></td>
                                            <td style="font-weight: 600;"><%= log.username %></td>
                                            <td style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= log.message %>">
                                                <%= log.message %>
                                            </td>
                                            <td style="white-space: nowrap;"><%= log.created_at ? new Date(log.created_at).toLocaleString('ru-RU') : '—' %></td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="log-empty">Нет записей чата</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>

                    <% } else { %>
                        <div class="log-empty">
                            <div style="font-size: 2rem; margin-bottom: 8px;">📋</div>
                            <p>Выберите тип логов</p>
                        </div>
                    <% } %>
                </div>

                <!-- ПАГИНАЦИЯ -->
                <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
                    <div class="pagination" style="margin-top: 20px;">
                        <% if (pagination.page > 1) { %>
                            <a href="/admin/logs?type=<%= typeof type !== 'undefined' ? type : 'punishments' %>&page=<%= pagination.page - 1 %>">←</a>
                        <% } else { %>
                            <span class="disabled">←</span>
                        <% } %>

                        <% for (var p = Math.max(1, pagination.page - 2); p <= Math.min(pagination.totalPages, pagination.page + 2); p++) { %>
                            <a href="/admin/logs?type=<%= typeof type !== 'undefined' ? type : 'punishments' %>&page=<%= p %>"
                               class="<%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
                        <% } %>

                        <% if (pagination.page < pagination.totalPages) { %>
                            <a href="/admin/logs?type=<%= typeof type !== 'undefined' ? type : 'punishments' %>&page=<%= pagination.page + 1 %>">→</a>
                        <% } else { %>
                            <span class="disabled">→</span>
                        <% } %>
                    </div>
                    <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 8px;">
                        Показаны <%= (pagination.page - 1) * pagination.perPage + 1 %>–<%= Math.min(pagination.page * pagination.perPage, pagination.totalCount) %> из <%= pagination.totalCount %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>