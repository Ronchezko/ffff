<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Перезапуск' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'restart' }) %>

        <div class="admin-content">
            <h1 class="text-gradient" style="margin-bottom: 24px;">🔄 Управление перезапуском</h1>

            <div class="grid grid-3" style="margin-bottom: 32px;">
                <div class="card" style="text-align: center;">
                    <div style="font-size: 3rem; margin-bottom: 12px;">💬</div>
                    <h3 style="margin-bottom: 8px;">Discord бот</h3>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 16px;">
                        Перезапуск Discord бота<br>Команды временно недоступны
                    </p>
                    <button class="btn btn-warning" onclick="restartService('discord')" data-confirm="Перезапустить Discord бота?">
                        🔄 Перезапустить Discord
                    </button>
                </div>

                <div class="card" style="text-align: center;">
                    <div style="font-size: 3rem; margin-bottom: 12px;">🎮</div>
                    <h3 style="margin-bottom: 8px;">Minecraft бот</h3>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 16px;">
                        Перезапуск Minecraft бота<br>Бот переподключится к серверу
                    </p>
                    <button class="btn btn-warning" onclick="restartService('minecraft')" data-confirm="Перезапустить Minecraft бота?">
                        🔄 Перезапустить Minecraft
                    </button>
                </div>

                <div class="card" style="text-align: center; border-color: var(--danger);">
                    <div style="font-size: 3rem; margin-bottom: 12px;">⚠️</div>
                    <h3 style="margin-bottom: 8px; color: var(--danger);">Полный перезапуск</h3>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 16px;">
                        Перезапуск ВСЕХ сервисов<br>Сайт, Discord, Minecraft
                    </p>
                    <button class="btn btn-danger" onclick="restartService('all')" data-confirm="⚠ Вы уверены? Это перезапустит ВСЕ сервисы!">
                        🔄 Полный перезапуск
                    </button>
                </div>
            </div>

            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">📊 Статус сервисов</h3>
                    <button class="btn btn-sm btn-outline" onclick="refreshStatus()">🔄 Обновить</button>
                </div>
                <div class="card-body">
                    <table>
                        <tbody>
                            <tr><td style="color: var(--text-secondary);">Discord бот</td><td><span class="badge badge-info" id="discordStatus">Проверка...</span></td></tr>
                            <tr><td style="color: var(--text-secondary);">Minecraft бот</td><td><span class="badge badge-info" id="minecraftStatus">Проверка...</span></td></tr>
                            <tr><td style="color: var(--text-secondary);">Веб-сервер</td><td><span class="badge badge-success">Онлайн</span></td></tr>
                            <tr><td style="color: var(--text-secondary);">База данных</td><td><span class="badge badge-success">Доступна</span></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function restartService(service) {
            if (!confirm('Вы уверены?')) return;
            var btn = event.target;
            var orig = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Выполнение...';

            try {
                var resp = await fetch('/api/admin/restart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ service: service }),
                });
                var data = await resp.json();
                alert(data.success ? 'Перезапуск initiated' : 'Ошибка: ' + (data.error || 'неизвестно'));
            } catch (err) {
                alert('Ошибка: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.textContent = orig;
            }
        }

        function refreshStatus() {
            document.getElementById('discordStatus').innerHTML = 'Онлайн';
            document.getElementById('discordStatus').className = 'badge badge-success';
            document.getElementById('minecraftStatus').innerHTML = 'Онлайн';
            document.getElementById('minecraftStatus').className = 'badge badge-success';
        }
    </script>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>