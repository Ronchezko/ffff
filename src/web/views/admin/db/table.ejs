<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Таблица <%= typeof tableName !== 'undefined' ? tableName : '' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .table-nav {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .table-nav a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.9rem;
        }
        .table-nav a:hover {
            color: var(--primary-lighter);
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        .data-table thead th {
            padding: 10px 12px;
            text-align: left;
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 1;
        }
        .data-table tbody td {
            padding: 8px 12px;
            border-bottom: 1px solid var(--border);
            max-width: 250px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .data-table tbody tr:hover td {
            background: rgba(99,67,212,0.05);
        }
        .table-container-scroll {
            max-height: 600px;
            overflow: auto;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
        }
        .row-actions {
            display: flex;
            gap: 4px;
        }
        .search-bar {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-bottom: 16px;
        }
        .search-bar input {
            width: 300px;
        }
    </style>
</head>
<body>
    <%- include('../../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../../partials/sidebar', { page: 'database' }) %>

        <div class="admin-content">
            <!-- НАВИГАЦИЯ -->
            <div class="table-nav">
                <a href="/admin/db">🗄️ БД</a>
                <span style="color: var(--text-muted);">/</span>
                <strong style="color: var(--text-bright);"><%= typeof tableName !== 'undefined' ? tableName : '' %></strong>
                <span class="badge badge-info"><%= typeof totalRows !== 'undefined' ? totalRows : 0 %> записей</span>
            </div>

            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; flex-wrap: wrap; gap: 12px;">
                <h1 class="text-gradient" style="margin-bottom: 0; font-size: 1.5rem;">📋 <%= typeof tableName !== 'undefined' ? tableName : '' %></h1>
                <div style="display: flex; gap: 8px;">
                    <a href="/admin/db/new/<%= typeof tableName !== 'undefined' ? tableName : '' %>" class="btn btn-primary btn-sm">➕ Новая запись</a>
                    <button class="btn btn-sm btn-outline" onclick="location.reload()">🔄 Обновить</button>
                </div>
            </div>

            <!-- ПОИСК -->
            <div class="search-bar">
                <input type="text" id="tableSearch" class="form-input" placeholder="Поиск по таблице..." oninput="filterTable()">
                <span style="color: var(--text-muted); font-size: 0.85rem;" id="searchResult"></span>
            </div>

            <!-- ТАБЛИЦА -->
            <div class="card">
                <div class="table-container-scroll">
                    <table class="data-table" id="dataTable">
                        <thead>
                            <tr>
                                <th style="width: 50px;">ID</th>
                                <% if (typeof columns !== 'undefined' && columns && columns.length > 0) { %>
                                    <% for (var i = 0; i < columns.length; i++) { %>
                                        <% if (columns[i] !== 'id') { %>
                                            <th><%= columns[i] %></th>
                                        <% } %>
                                    <% } %>
                                <% } %>
                                <th style="width: 80px;">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof rows !== 'undefined' && rows && rows.length > 0) { %>
                                <% for (var r = 0; r < rows.length; r++) { 
                                    var row = rows[r];
                                %>
                                    <tr>
                                        <td><%= row.id %></td>
                                        <% if (typeof columns !== 'undefined' && columns && columns.length > 0) { %>
                                            <% for (var c = 0; c < columns.length; c++) { 
                                                var col = columns[c];
                                                if (col === 'id') continue;
                                                var value = row[col];
                                                var displayValue = value !== null && value !== undefined ? String(value) : '—';
                                                if (displayValue.length > 100) displayValue = displayValue.substring(0, 100) + '...';
                                            %>
                                                <td title="<%= value !== null && value !== undefined ? String(value) : '' %>"><%= displayValue %></td>
                                            <% } %>
                                        <% } %>
                                        <td>
                                            <div class="row-actions">
                                                <a href="/admin/db/edit/<%= typeof tableName !== 'undefined' ? tableName : '' %>/<%= row.id %>" class="btn btn-sm btn-outline" title="Редактировать">✏️</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            <% } else { %>
                                <tr>
                                    <td colspan="100" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                        Нет записей в таблице
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- ПАГИНАЦИЯ -->
                <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                    <div class="pagination" style="margin-top: 20px;">
                        <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                            <a href="/admin/db/table/<%= typeof tableName !== 'undefined' ? tableName : '' %>?page=<%= currentPage - 1 %>">←</a>
                        <% } else { %>
                            <span class="disabled">←</span>
                        <% } %>

                        <% for (var p = Math.max(1, (typeof currentPage !== 'undefined' ? currentPage : 1) - 2); p <= Math.min((typeof totalPages !== 'undefined' ? totalPages : 1), (typeof currentPage !== 'undefined' ? currentPage : 1) + 2); p++) { %>
                            <a href="/admin/db/table/<%= typeof tableName !== 'undefined' ? tableName : '' %>?page=<%= p %>"
                               class="<%= p === (typeof currentPage !== 'undefined' ? currentPage : 1) ? 'active' : '' %>"><%= p %></a>
                        <% } %>

                        <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage < totalPages) { %>
                            <a href="/admin/db/table/<%= typeof tableName !== 'undefined' ? tableName : '' %>?page=<%= currentPage + 1 %>">→</a>
                        <% } else { %>
                            <span class="disabled">→</span>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        function filterTable() {
            var input = document.getElementById('tableSearch');
            var filter = input.value.toLowerCase();
            var table = document.getElementById('dataTable');
            var rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
            var visibleCount = 0;

            for (var i = 0; i < rows.length; i++) {
                var row = rows[i];
                var text = row.textContent || row.innerText || '';
                if (text.toLowerCase().indexOf(filter) > -1) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            }

            var resultEl = document.getElementById('searchResult');
            if (filter) {
                resultEl.textContent = 'Найдено: ' + visibleCount;
            } else {
                resultEl.textContent = '';
            }
        }
    </script>

    <%- include('../../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>