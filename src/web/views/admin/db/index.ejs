<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>База данных — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .db-table-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }
        .db-table-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px;
            cursor: pointer;
            transition: all 0.25s ease;
            text-decoration: none;
            color: var(--text-primary);
            display: block;
        }
        .db-table-card:hover {
            border-color: var(--primary);
            box-shadow: var(--shadow-glow);
            transform: translateY(-2px);
            text-decoration: none;
            color: var(--text-primary);
        }
        .db-table-name {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--text-bright);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .db-table-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--primary), var(--primary-lighter));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }
        .db-table-info {
            font-size: 0.85rem;
            color: var(--text-secondary);
            display: flex;
            justify-content: space-between;
        }
        .db-table-count {
            font-weight: 700;
            color: var(--info);
        }
        .db-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }
        .db-stat-item {
            text-align: center;
            padding: 20px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }
        .db-stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary-lighter);
        }
        .db-stat-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }
    </style>
</head>
<body>
    <%- include('../../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../../partials/sidebar', { page: 'database' }) %>

        <div class="admin-content">
            <h1 class="text-gradient" style="margin-bottom: 8px;">🗄️ База данных</h1>
            <p style="color: var(--text-secondary); margin-bottom: 32px;">
                Прямой доступ к таблицам базы данных Resistance
            </p>

            <!-- СТАТИСТИКА БД -->
            <div class="db-stats">
                <div class="db-stat-item">
                    <div class="db-stat-value"><%= typeof tableCount !== 'undefined' ? tableCount : 0 %></div>
                    <div class="db-stat-label">Таблиц</div>
                </div>
                <div class="db-stat-item">
                    <div class="db-stat-value"><%= typeof totalRows !== 'undefined' ? totalRows : 0 %></div>
                    <div class="db-stat-label">Всего записей</div>
                </div>
                <div class="db-stat-item">
                    <div class="db-stat-value"><%= typeof dbSize !== 'undefined' ? dbSize : '0' %> MB</div>
                    <div class="db-stat-label">Размер БД</div>
                </div>
                <div class="db-stat-item">
                    <div class="db-stat-value"><%= typeof lastBackup !== 'undefined' && lastBackup ? lastBackup : '—' %></div>
                    <div class="db-stat-label">Последний бэкап</div>
                </div>
            </div>

            <!-- СПИСОК ТАБЛИЦ -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">📋 Таблицы базы данных</h3>
                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-sm btn-outline" onclick="refreshTables()">🔄 Обновить</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="db-table-list">
                        <% if (typeof tables !== 'undefined' && tables && tables.length > 0) { %>
                            <% for (var i = 0; i < tables.length; i++) { 
                                var table = tables[i];
                                var icons = {
                                    'members': '👤',
                                    'rp_members': '📋',
                                    'balance_logs': '💰',
                                    'punishment_logs': '🔨',
                                    'clan_chat_logs': '💬',
                                    'staff': '👥',
                                    'settings': '⚙️',
                                    'verification_codes': '🔗',
                                    'properties': '🏠',
                                    'businesses': '🏪',
                                    'offices': '🏛️',
                                    'licenses': '📄',
                                    'organizations': '🏢',
                                    'gangs': '🔫',
                                    'robbery_parties': '💰',
                                    'army_supplies': '🛡️',
                                    'diseases': '🦠',
                                    'medical_books': '📕',
                                    'education': '🎓',
                                    'bank_accounts': '🏦',
                                    'bank_transactions': '💳',
                                    'jail_records': '🔒',
                                    'fines': '📋',
                                    'vacations': '🏖️',
                                    'staff_warns': '⚠️',
                                    'org_warns': '⚠️',
                                    'org_blacklists': '🚫',
                                    'command_cooldowns': '⏱️',
                                    'private_message_logs': '✉️',
                                    'active_duties': '🟢',
                                };
                                var icon = icons[table.name] || '📦';
                            %>
                                <a href="/admin/db/table/<%= table.name %>" class="db-table-card">
                                    <div class="db-table-name">
                                        <div class="db-table-icon"><%= icon %></div>
                                        <%= table.name %>
                                    </div>
                                    <div class="db-table-info">
                                        <span>Записей:</span>
                                        <span class="db-table-count"><%= table.rowCount || 0 %></span>
                                    </div>
                                </a>
                            <% } %>
                        <% } else { %>
                            <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                                <div style="font-size: 2rem; margin-bottom: 8px;">📭</div>
                                <p>Нет данных о таблицах</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function refreshTables() {
            location.reload();
        }
    </script>

    <%- include('../../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>