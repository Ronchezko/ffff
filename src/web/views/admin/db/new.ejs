<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Новая запись | Resistance</title>
    <link rel="icon" type="image/png" href="/images/logo.jpg">
    <style>
        body { font-family: 'Segoe UI', Roboto, sans-serif; background: #f5f7fa; padding: 40px; }
        .container { max-width: 800px; margin: 0 auto; background: white; border-radius: 20px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        h1 { color: #4a3aff; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: 600; }
        input { width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 10px; }
        .btn { padding: 10px 25px; background: #4a3aff; color: white; border: none; border-radius: 30px; cursor: pointer; }
        .btn:hover { background: #3728e0; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Новая запись в таблице <%= table %></h1>
        <form method="POST" action="/admin/db/<%= table %>/new">
            <% columns.forEach(col => { %>
                <% if (col.name !== 'id') { %>
                    <div class="form-group">
                        <label for="<%= col.name %>"><%= col.name %></label>
                        <input type="text" id="<%= col.name %>" name="<%= col.name %>" value="">
                    </div>
                <% } %>
            <% }) %>
            <button type="submit" class="btn">Создать</button>
            <a href="/admin/db/<%= table %>" class="btn" style="background:#999;">Отмена</a>
        </form>
    </div>
</body>
</html>