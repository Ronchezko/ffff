<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Редактирование — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../../partials/sidebar', { page: 'database' }) %>

        <div class="admin-content">
            <div class="table-nav" style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
                <a href="/admin/db" style="color: var(--text-secondary);">🗄️ БД</a>
                <span style="color: var(--text-muted);">/</span>
                <a href="/admin/db/table/<%= typeof tableName !== 'undefined' ? tableName : '' %>" style="color: var(--text-secondary);"><%= typeof tableName !== 'undefined' ? tableName : '' %></a>
                <span style="color: var(--text-muted);">/</span>
                <strong style="color: var(--text-bright);">Запись #<%= typeof rowId !== 'undefined' ? rowId : '' %></strong>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">✏️ Редактирование записи #<%= typeof rowId !== 'undefined' ? rowId : '' %></h3>
                    <span class="badge badge-info">Таблица: <%= typeof tableName !== 'undefined' ? tableName : '' %></span>
                </div>
                <div class="card-body">
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div style="background: rgba(202,78,78,0.1); border: 1px solid var(--danger); border-radius: 8px; padding: 12px 16px; color: var(--danger); margin-bottom: 16px;">
                            <%= error %>
                        </div>
                    <% } %>

                    <% if (typeof success !== 'undefined' && success) { %>
                        <div style="background: rgba(118,197,25,0.1); border: 1px solid var(--success); border-radius: 8px; padding: 12px 16px; color: var(--success); margin-bottom: 16px;">
                            <%= success %>
                        </div>
                    <% } %>

                    <form method="POST" action="/admin/db/edit/<%= typeof tableName !== 'undefined' ? tableName : '' %>/<%= typeof rowId !== 'undefined' ? rowId : '' %>">
                        <% if (typeof columns !== 'undefined' && columns && typeof row !== 'undefined' && row) { %>
                            <% for (var i = 0; i < columns.length; i++) { 
                                var col = columns[i];
                                var value = row[col] !== null && row[col] !== undefined ? row[col] : '';
                            %>
                                <div class="form-group">
                                    <label class="form-label"><%= col %></label>
                                    <% if (col === 'id') { %>
                                        <input type="text" class="form-input" value="<%= value %>" disabled>
                                        <small style="color: var(--text-muted);">ID нельзя изменить</small>
                                    <% } else if (typeof value === 'string' && value.length > 200) { %>
                                        <textarea name="<%= col %>" class="form-textarea" rows="6"><%= value %></textarea>
                                    <% } else if (typeof value === 'number') { %>
                                        <input type="number" name="<%= col %>" class="form-input" value="<%= value %>" step="any">
                                    <% } else { %>
                                        <input type="text" name="<%= col %>" class="form-input" value="<%= value %>">
                                    <% } %>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p style="color: var(--text-muted);">Нет данных для редактирования</p>
                        <% } %>

                        <div style="display: flex; gap: 12px; margin-top: 24px;">
                            <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                            <a href="/admin/db/table/<%= typeof tableName !== 'undefined' ? tableName : '' %>" class="btn btn-outline">← Назад</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>