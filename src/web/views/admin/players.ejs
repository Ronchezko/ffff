<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Управление игроками' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .search-form {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .search-form input {
            width: 250px;
        }
    </style>
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'players' }) %>

        <div class="admin-content">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
                <div>
                    <h1 class="text-gradient" style="margin-bottom: 4px;">👥 Управление игроками</h1>
                    <p style="color: var(--text-secondary);">
                        Всего: <strong><%= typeof pagination !== 'undefined' && pagination ? pagination.totalCount : 0 %></strong> игроков
                    </p>
                </div>
                <form method="GET" action="/admin/players" class="search-form">
                    <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Поиск игрока..." class="form-input">
                    <button type="submit" class="btn btn-primary btn-sm">🔍 Найти</button>
                    <% if (typeof search !== 'undefined' && search) { %>
                        <a href="/admin/players" class="btn btn-sm btn-outline">✕ Сброс</a>
                    <% } %>
                </form>
            </div>

            <div class="card">
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Игрок</th>
                                <th>Баланс</th>
                                <th>Организация</th>
                                <th>Ранг</th>
                                <th>Баллы</th>
                                <th>В городе</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof players !== 'undefined' && players && players.length > 0) { %>
                                <% for (var i = 0; i < players.length; i++) { 
                                    var player = players[i];
                                %>
                                    <tr>
                                        <td><%= player.id %></td>
                                        <td>
                                            <a href="/profile/<%= player.username %>" style="font-weight: 600; color: var(--text-bright);">
                                                <%= player.username %>
                                            </a>
                                        </td>
                                        <td style="font-weight: 700; color: var(--success);">
                                            <%= (player.balance || 0).toLocaleString() %> ₽
                                        </td>
                                        <td><%= player.organization || '—' %></td>
                                        <td><%= player.rank || '—' %></td>
                                        <td style="color: var(--primary-lighter);"><%= player.points || 0 %></td>
                                        <td>
                                            <% if (player.is_in_city) { %>
                                                <span class="badge badge-success">Да</span>
                                            <% } else { %>
                                                <span class="badge badge-warning">Нет</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                                                <% if (player.is_in_jail) { %>
                                                    <span class="badge badge-danger">Тюрьма</span>
                                                <% } %>
                                                <% if (player.is_sick) { %>
                                                    <span class="badge badge-warning">Болен</span>
                                                <% } %>
                                                <% if (player.is_frozen) { %>
                                                    <span class="badge badge-info">Заморожен</span>
                                                <% } %>
                                                <% if (!player.is_in_jail && !player.is_sick && !player.is_frozen) { %>
                                                    <span class="badge badge-success">OK</span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td>
                                            <a href="/profile/<%= player.username %>" class="btn btn-sm btn-outline" title="Профиль">👤</a>
                                        </td>
                                    </tr>
                                <% } %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9" style="text-align: center; color: var(--text-muted); padding: 40px;">
                                        <% if (typeof search !== 'undefined' && search) { %>
                                            Игроки не найдены по запросу "<%= search %>"
                                        <% } else { %>
                                            Нет игроков в базе данных
                                        <% } %>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
                    <div class="pagination" style="margin-top: 20px;">
                        <% if (pagination.page > 1) { %>
                            <a href="/admin/players?page=<%= pagination.page - 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">←</a>
                        <% } else { %>
                            <span class="disabled">←</span>
                        <% } %>

                        <% for (var p = Math.max(1, pagination.page - 2); p <= Math.min(pagination.totalPages, pagination.page + 2); p++) { %>
                            <a href="/admin/players?page=<%= p %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>"
                               class="<%= p === pagination.page ? 'active' : '' %>"><%= p %></a>
                        <% } %>

                        <% if (pagination.page < pagination.totalPages) { %>
                            <a href="/admin/players?page=<%= pagination.page + 1 %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>">→</a>
                        <% } else { %>
                            <span class="disabled">→</span>
                        <% } %>
                    </div>
                    <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 8px;">
                        Показаны <%= (pagination.page - 1) * pagination.perPage + 1 %>–<%= Math.min(pagination.page * pagination.perPage, pagination.totalCount) %> из <%= pagination.totalCount %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>