<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Консоль управления' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .console-output-area {
            background: #0a0a14;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 16px;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            font-size: 0.85rem;
            color: #a0ffa0;
            min-height: 350px;
            max-height: 500px;
            overflow-y: auto;
            white-space: pre-wrap;
            word-break: break-all;
            line-height: 1.6;
        }
        .console-output-area .c-error { color: #ff6b6b; }
        .console-output-area .c-warn { color: #ffb800; }
        .console-output-area .c-info { color: #80c4c5; }
        .console-output-area .c-success { color: #76c519; }
        .console-output-area .c-time { color: #555; }
        .console-output-area .c-input { color: #ffb800; }
        .console-input-row {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            align-items: center;
        }
        .console-prefix {
            color: var(--success);
            font-family: 'Consolas', monospace;
            font-weight: 700;
            white-space: nowrap;
            font-size: 0.9rem;
        }
        .console-input-row input {
            flex: 1;
            background: #0a0a14;
            border: 1px solid var(--border);
            color: #a0ffa0;
            font-family: 'Consolas', monospace;
            padding: 10px 16px;
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
        }
        .console-input-row input:focus {
            outline: none;
            border-color: var(--primary);
        }
        .quick-cmd-btn {
            padding: 6px 12px;
            border-radius: 4px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.8rem;
            font-family: var(--font-mono);
            transition: all 0.15s ease;
        }
        .quick-cmd-btn:hover {
            background: rgba(99,67,212,0.1);
            border-color: var(--primary);
            color: var(--text-bright);
        }
        .history-item {
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-family: var(--font-mono);
            font-size: 0.85rem;
            color: var(--text-secondary);
            transition: all 0.15s ease;
        }
        .history-item:hover {
            background: rgba(99,67,212,0.1);
            color: var(--text-bright);
        }
    </style>
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'console' }) %>

        <div class="admin-content">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
                <div>
                    <h1 class="text-gradient" style="margin-bottom: 4px;">💻 Консоль управления</h1>
                    <p style="color: var(--text-secondary);">Отправка команд Minecraft боту напрямую</p>
                </div>
                <div style="display: flex; gap: 8px;">
                    <button class="btn btn-sm btn-outline" onclick="clearConsoleOutput()">🗑️ Очистить</button>
                    <button class="btn btn-sm btn-outline" onclick="exportConsoleLog()">📥 Экспорт</button>
                </div>
            </div>

            <!-- ВЫВОД КОНСОЛИ -->
            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">📺 Вывод</h3>
                </div>
                <div class="card-body">
                    <div class="console-output-area" id="consoleOutput">
                        <span class="c-time">[<%= new Date().toLocaleTimeString('ru-RU') %>]</span> <span class="c-info">Консоль готова. Введите команду...</span>
                    </div>

                    <div class="console-input-row">
                        <span class="console-prefix">resistance@admin&gt;</span>
                        <input type="text"
                               id="consoleInput"
                               placeholder="Введите команду (например: /c kick Player причина)..."
                               autocomplete="off"
                               onkeydown="handleConsoleKey(event)">
                        <button class="btn btn-primary btn-sm" onclick="sendConsoleCommand()" style="flex-shrink: 0;">▶ Выполнить</button>
                    </div>
                </div>
            </div>

            <!-- БЫСТРЫЕ КОМАНДЫ -->
            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">⚡ Быстрые команды</h3>
                </div>
                <div class="card-body">
                    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                        <button class="quick-cmd-btn" onclick="quickCommand('/c kick ')">/c kick</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/c mute ')">/c mute</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/c unmute ')">/c unmute</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/c accept ')">/c accept</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/c rank ')">/c rank</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/rg addmember ')">/rg addmember</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/rg removemember ')">/rg removemember</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/eco set ')">/eco set</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/msg ')">/msg</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/cc ')">/cc</button>
                        <button class="quick-cmd-btn" onclick="quickCommand('/fly ')">/fly</button>
                    </div>
                </div>
            </div>

            <!-- ПОЛЕЗНЫЕ КОМАНДЫ -->
            <div class="card" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">📋 Полезные команды</h3>
                </div>
                <div class="card-body">
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                        <% 
                            var usefulCommands = [
                                { cmd: '/c kick {ник}', desc: 'Кикнуть из клана' },
                                { cmd: '/c mute {ник} {причина}', desc: 'Замутить в клане' },
                                { cmd: '/c unmute {ник}', desc: 'Размутить' },
                                { cmd: '/c accept {ник}', desc: 'Принять заявку' },
                                { cmd: '/c rank {ник} {ранг}', desc: 'Выдать ранг' },
                                { cmd: '/rg addmember TRTR{id} {ник}', desc: 'Добавить в регион' },
                                { cmd: '/rg removemember TRTR{id} {ник}', desc: 'Удалить из региона' },
                                { cmd: '/rg flag TRTR{id} use allow/deny', desc: 'Флаг региона' },
                                { cmd: '/eco set {ник} {сумма}', desc: 'Установить баланс' },
                                { cmd: '/msg {ник} {текст}', desc: 'Личное сообщение' },
                                { cmd: '/cc {текст}', desc: 'В клановый чат' },
                                { cmd: '/fly {ник}', desc: 'Выдать флай' },
                            ];
                            for (var i = 0; i < usefulCommands.length; i++) {
                                var cmd = usefulCommands[i];
                        %>
                            <div style="padding: 10px; border-radius: 6px; background: rgba(255,255,255,0.02); cursor: pointer;"
                                 onclick="quickCommand('<%= cmd.cmd %> ')" title="Нажмите для вставки">
                                <code style="color: var(--info); font-family: var(--font-mono);"><%= cmd.cmd %></code>
                                <span style="color: var(--text-muted); margin-left: 8px; font-size: 0.85rem;"><%= cmd.desc %></span>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- ИСТОРИЯ -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">📜 История команд</h3>
                    <button class="btn btn-sm btn-outline" onclick="clearHistory()">Очистить</button>
                </div>
                <div class="card-body" id="commandHistoryContainer">
                    <p style="color: var(--text-muted); text-align: center;">История пуста</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        var commandHistory = [];
        var historyIndex = -1;

        function handleConsoleKey(event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                sendConsoleCommand();
            } else if (event.key === 'ArrowUp') {
                event.preventDefault();
                if (historyIndex < commandHistory.length - 1) {
                    historyIndex++;
                    document.getElementById('consoleInput').value = commandHistory[commandHistory.length - 1 - historyIndex] || '';
                }
            } else if (event.key === 'ArrowDown') {
                event.preventDefault();
                if (historyIndex > 0) {
                    historyIndex--;
                    document.getElementById('consoleInput').value = commandHistory[commandHistory.length - 1 - historyIndex] || '';
                } else {
                    historyIndex = -1;
                    document.getElementById('consoleInput').value = '';
                }
            }
        }

        async function sendConsoleCommand() {
            var input = document.getElementById('consoleInput');
            var command = input.value.trim();
            if (!command) return;

            commandHistory.push(command);
            historyIndex = -1;
            updateHistoryDisplay();
            appendToConsole(command, 'input');

            try {
                var response = await fetch('/api/admin/command', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ command: command }),
                });
                var data = await response.json();
                if (data.success) {
                    appendToConsole(data.message || 'Команда отправлена', 'success');
                } else {
                    appendToConsole(data.error || 'Ошибка', 'error');
                }
            } catch (err) {
                appendToConsole('Ошибка: ' + err.message, 'error');
            }

            input.value = '';
            input.focus();
        }

        function quickCommand(cmd) {
            document.getElementById('consoleInput').value = cmd;
            document.getElementById('consoleInput').focus();
        }

        function appendToConsole(text, type) {
            var output = document.getElementById('consoleOutput');
            var time = new Date().toLocaleTimeString('ru-RU');
            var line = document.createElement('div');
            if (type === 'input') {
                line.innerHTML = '<span class="c-time">[' + time + ']</span> <span class="c-input">&gt; ' + escapeHtml(text) + '</span>';
            } else {
                line.innerHTML = '<span class="c-time">[' + time + ']</span> <span class="c-' + type + '">' + escapeHtml(text) + '</span>';
            }
            output.appendChild(line);
            output.scrollTop = output.scrollHeight;
        }

        function clearConsoleOutput() {
            var output = document.getElementById('consoleOutput');
            var time = new Date().toLocaleTimeString('ru-RU');
            output.innerHTML = '<span class="c-time">[' + time + ']</span> <span class="c-info">Консоль очищена.</span>';
        }

        function exportConsoleLog() {
            var output = document.getElementById('consoleOutput');
            var text = output.innerText;
            var blob = new Blob([text], { type: 'text/plain' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'console-' + new Date().toISOString().replace(/[:.]/g, '-') + '.log';
            a.click();
            URL.revokeObjectURL(url);
        }

        function updateHistoryDisplay() {
            var container = document.getElementById('commandHistoryContainer');
            if (commandHistory.length === 0) {
                container.innerHTML = '<p style="color: var(--text-muted); text-align: center;">История пуста</p>';
                return;
            }
            var html = '';
            var reversed = commandHistory.slice().reverse().slice(0, 30);
            for (var i = 0; i < reversed.length; i++) {
                html += '<div class="history-item" onclick="quickCommand(\'' + escapeHtml(reversed[i]) + ' \')">' + escapeHtml(reversed[i]) + '</div>';
            }
            container.innerHTML = html;
        }

        function clearHistory() {
            commandHistory = [];
            historyIndex = -1;
            updateHistoryDisplay();
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('consoleInput').focus();
        });
    </script>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>