<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Админ-панель' %> — Resistance Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .stat-card-small {
            text-align: center;
            padding: 20px 16px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            transition: all 0.3s ease;
        }
        .stat-card-small:hover {
            border-color: var(--primary);
            box-shadow: var(--shadow-glow);
        }
        .quick-actions {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .event-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 12px;
            border-radius: 6px;
            background: rgba(255,255,255,0.02);
            margin-bottom: 4px;
        }
    </style>
</head>
<body>
    <%- include('../partials/header', { page: 'admin' }) %>

    <div class="admin-layout">
        <%- include('../partials/sidebar', { page: 'dashboard' }) %>

        <div class="admin-content">
            <h1 class="text-gradient" style="margin-bottom: 8px;">📊 Админ-панель</h1>
            <p style="color: var(--text-secondary); margin-bottom: 32px;">
                Добро пожаловать, <strong><%= typeof user !== 'undefined' && user ? user.username : 'Администратор' %></strong>!
                Вход: <%= typeof user !== 'undefined' && user && user.loginTime ? new Date(user.loginTime).toLocaleString('ru-RU') : '—' %>
            </p>

            <!-- СТАТ-КАРТОЧКИ -->
            <div class="grid grid-4" style="margin-bottom: 24px;">
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">👥</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--primary-lighter);"><%= typeof stats !== 'undefined' && stats ? stats.rpCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Участников RP</div>
                </div>
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">⚔️</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--primary-lighter);"><%= typeof stats !== 'undefined' && stats ? stats.clanCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">В клане</div>
                </div>
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🟢</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--success);"><%= typeof stats !== 'undefined' && stats ? stats.onlineCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">В городе</div>
                </div>
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">💰</div>
                    <% var totalMoney = (typeof stats !== 'undefined' && stats && stats.totalMoney) ? stats.totalMoney : 0; %>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--success);"><%= Math.floor(totalMoney / 1000000) %>M</div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">В экономике</div>
                </div>
            </div>

            <!-- ВТОРОЙ РЯД -->
            <div class="grid grid-4" style="margin-bottom: 24px;">
                <div class="stat-card-small" style="border-color: var(--danger);">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🔒</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--danger);"><%= typeof stats !== 'undefined' && stats ? stats.jailedCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">В тюрьме</div>
                </div>
                <div class="stat-card-small" style="border-color: var(--warning);">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🤒</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--warning);"><%= typeof stats !== 'undefined' && stats ? stats.sickCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Больны</div>
                </div>
                <div class="stat-card-small" style="border-color: var(--info);">
                    <div style="font-size: 2rem; margin-bottom: 4px;">❄️</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--info);"><%= typeof stats !== 'undefined' && stats ? stats.frozenCount : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Заморожено</div>
                </div>
                <div class="stat-card-small" style="border-color: var(--primary);">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🏠</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--primary-lighter);"><%= typeof stats !== 'undefined' && stats ? stats.propertiesOwned : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Занятой недвижимости</div>
                </div>
            </div>

            <!-- ТРЕТИЙ РЯД -->
            <div class="grid grid-3" style="margin-bottom: 24px;">
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">💰</div>
                    <% var totalMoney2 = (typeof stats !== 'undefined' && stats && stats.totalMoney) ? stats.totalMoney : 0; %>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--success);"><%= Math.floor(totalMoney2 / 1000) %>K</div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Денег у игроков</div>
                </div>
                <div class="stat-card-small">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🏦</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--info);"><%= Math.floor((typeof stats !== 'undefined' && stats ? stats.totalBankMoney : 0) / 1000) %>K</div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">В банках</div>
                </div>
                <div class="stat-card-small" style="border-color: var(--warning);">
                    <div style="font-size: 2rem; margin-bottom: 4px;">🔨</div>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--warning);"><%= typeof stats !== 'undefined' && stats ? stats.activePunishments : 0 %></div>
                    <div style="font-size: 0.85rem; color: var(--text-secondary);">Активных наказаний</div>
                </div>
            </div>

            <div class="grid grid-2" style="margin-bottom: 24px;">
                <!-- БЫСТРЫЕ ДЕЙСТВИЯ -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">⚡ Быстрые действия</h3>
                    </div>
                    <div class="card-body">
                        <div class="quick-actions">
                            <a href="/admin/players" class="btn btn-primary">👥 Управление игроками</a>
                            <a href="/admin/properties" class="btn btn-outline">🏠 Управление имуществом</a>
                            <a href="/admin/console" class="btn btn-outline">💻 Консоль команд</a>
                            <a href="/admin/logs" class="btn btn-outline">📋 Просмотр логов</a>
                            <a href="/admin/settings" class="btn btn-outline">⚙️ Настройки</a>
                            <a href="/admin/restart" class="btn btn-outline" style="color: var(--warning);">🔄 Перезапуск сервисов</a>
                        </div>
                    </div>
                </div>

                <!-- ПОСЛЕДНИЕ СОБЫТИЯ -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">📋 Последние события</h3>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        <% if (typeof recentEvents !== 'undefined' && recentEvents && recentEvents.length > 0) { %>
                            <% for (var e = 0; e < recentEvents.length; e++) { 
                                var event = recentEvents[e];
                            %>
                                <div class="event-row">
                                    <span style="font-size: 1.2rem;"><%= event.icon %></span>
                                    <div style="flex: 1;">
                                        <span style="font-size: 0.9rem;"><%= event.text %></span>
                                    </div>
                                    <span style="font-size: 0.75rem; color: var(--text-muted); white-space: nowrap;">
                                        <%= event.time ? new Date(event.time).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' }) : '—' %>
                                    </span>
                                </div>
                            <% } %>
                        <% } else { %>
                            <p style="color: var(--text-muted); text-align: center; padding: 20px;">Нет событий</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- СТАТУС НАКАЗАНИЙ -->
            <div class="grid grid-3" style="margin-bottom: 24px;">
                <div class="card" style="text-align: center;">
                    <h4 style="color: var(--warning);">🔇 Мутов</h4>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--warning);"><%= typeof stats !== 'undefined' && stats ? stats.activeMutes : 0 %></div>
                </div>
                <div class="card" style="text-align: center;">
                    <h4 style="color: var(--danger);">🚫 В ЧС</h4>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--danger);"><%= typeof stats !== 'undefined' && stats ? stats.activeBlacklists : 0 %></div>
                </div>
                <div class="card" style="text-align: center;">
                    <h4 style="color: var(--info);">📋 Всего</h4>
                    <div style="font-size: 2rem; font-weight: 800; color: var(--info);"><%= typeof stats !== 'undefined' && stats ? stats.activePunishments : 0 %></div>
                </div>
            </div>

            <!-- ИНФОРМАЦИЯ -->
            <div class="card" style="background: linear-gradient(135deg, rgba(99,67,212,0.1), transparent);">
                <div class="card-header">
                    <h3 class="card-title">🖥️ Информация о системе</h3>
                </div>
                <div class="card-body">
                    <table>
                        <tbody>
                            <tr>
                                <td style="color: var(--text-secondary);">Сервер Minecraft</td>
                                <td style="font-weight: 600;">ru.dexland.org:25565</td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Бот Minecraft</td>
                                <td style="font-weight: 600;">YT_FLATT807</td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Версия системы</td>
                                <td style="font-weight: 600; color: var(--primary-lighter);">5.0.0</td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Режим</td>
                                <td style="font-weight: 600;"><%= typeof process !== 'undefined' && process.env && process.env.NODE_ENV ? process.env.NODE_ENV : 'development' %></td>
                            </tr>
                            <tr>
                                <td style="color: var(--text-secondary);">Время работы</td>
                                <td style="font-weight: 600;"><%= typeof process !== 'undefined' && process.uptime ? Math.floor(process.uptime() / 3600) + 'ч ' + Math.floor((process.uptime() % 3600) / 60) + 'м' : '—' %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>