<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Админ-панель | Resistance</title>
    <link rel="icon" type="image/png" href="/images/logo.jpg">
    <style>
        /* ===== ОБЩИЕ СТИЛИ ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        :root {
            --bg-color: #f5f7fa;
            --text-color: #333;
            --card-bg: #ffffff;
            --header-bg: rgba(255,255,255,0.95);
            --border-color: rgba(0,0,0,0.1);
            --primary: #4a3aff;
            --primary-hover: #3728e0;
            --success: #00d25b;
            --danger: #ff4757;
            --warning: #ffaa00;
            --info: #00bfff;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(45deg, #6343d4, #aa4eff);
            --gradient-3: linear-gradient(45deg, #00d25b, #00bfff);
            --gradient-4: linear-gradient(45deg, #ff4757, #ff6b81);
            --gradient-5: linear-gradient(45deg, #ffaa00, #ffd700);
            --shadow-sm: 0 10px 30px rgba(0,0,0,0.05);
            --shadow-md: 0 15px 40px rgba(0,0,0,0.1);
            --shadow-lg: 0 20px 50px rgba(0,0,0,0.2);
        }

        [data-theme="dark"] {
            --bg-color: #0b0c1e;
            --text-color: #e0e0e0;
            --card-bg: #1a1b2f;
            --header-bg: rgba(10,10,20,0.95);
            --border-color: rgba(255,255,255,0.1);
            --primary: #aa4eff;
            --primary-hover: #8a3fcc;
            --success: #00d25b;
            --danger: #ff6b81;
            --warning: #ffaa00;
            --info: #00bfff;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: background 0.3s, color 0.3s;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background: var(--header-bg);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 50px;
            filter: drop-shadow(0 0 10px rgba(170,78,255,0.5));
        }

        .logo h2 {
            font-size: 1.8rem;
            background: var(--gradient-2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            color: transparent;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .btn-logout {
            padding: 8px 20px;
            background: var(--gradient-2);
            color: white;
            text-decoration: none;
            border-radius: 30px;
            font-weight: 600;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .btn-logout:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(170,78,255,0.4);
        }

        .theme-toggle {
            background: none;
            border: 1px solid var(--border-color);
            cursor: pointer;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-color);
            font-size: 1.5rem;
            transition: background 0.3s;
        }

        .theme-toggle:hover {
            background: rgba(128,128,128,0.2);
        }

        .container {
            max-width: 1400px;
            margin: 40px auto;
            padding: 0 20px;
            flex: 1;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 30px;
            background: var(--gradient-2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: inline-block;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin-bottom: 50px;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: 30px;
            padding: 30px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-color);
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: var(--gradient-2);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            background: var(--gradient-2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 2rem;
        }

        .stat-card h3 {
            font-size: 1.2rem;
            color: var(--footer-color);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-value {
            font-size: 3rem;
            font-weight: 700;
            color: var(--primary);
            line-height: 1.2;
        }

        /* ===== НОВЫЙ ДИЗАЙН БЫСТРЫХ ДЕЙСТВИЙ ===== */
        .actions-section {
            margin-bottom: 50px;
        }

        .section-title {
            font-size: 2rem;
            margin-bottom: 25px;
            color: var(--text-color);
            border-bottom: 2px solid var(--primary);
            padding-bottom: 10px;
            display: inline-block;
        }

        .action-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .action-card {
            background: var(--card-bg);
            border-radius: 25px;
            padding: 25px 20px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-color);
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
            color: var(--text-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .action-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--gradient-2);
            transform: translateY(-100%);
            transition: transform 0.3s;
        }

        .action-card:hover::before {
            transform: translateY(0);
        }

        .action-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .action-card.danger::before {
            background: var(--gradient-4);
        }

        .action-card.warning::before {
            background: var(--gradient-5);
        }

        .action-card.info::before {
            background: var(--gradient-3);
        }

        .action-icon {
            width: 60px;
            height: 60px;
            background: var(--gradient-2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            font-size: 2rem;
            color: white;
            transition: transform 0.3s;
        }

        .action-card.danger .action-icon {
            background: var(--gradient-4);
        }

        .action-card.warning .action-icon {
            background: var(--gradient-5);
        }

        .action-card.info .action-icon {
            background: var(--gradient-3);
        }

        .action-card:hover .action-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .action-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .action-desc {
            font-size: 0.9rem;
            color: var(--footer-color);
        }

        .quick-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .quick-stat {
            background: rgba(74,58,255,0.05);
            border-radius: 15px;
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quick-stat-icon {
            width: 40px;
            height: 40px;
            background: var(--gradient-2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
        }

        .quick-stat-info h4 {
            font-size: 0.9rem;
            color: var(--footer-color);
        }

        .quick-stat-info span {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--primary);
        }

        /* ===== ОСТАЛЬНЫЕ СТИЛИ ===== */
        .recent-activity {
            background: var(--card-bg);
            border-radius: 30px;
            padding: 25px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-color);
            margin-bottom: 50px;
        }

        .recent-activity h2 {
            font-size: 1.8rem;
            margin-bottom: 20px;
            color: var(--primary);
        }

        .activity-list {
            list-style: none;
        }

        .activity-item {
            display: flex;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-time {
            min-width: 80px;
            color: var(--footer-color);
            font-size: 0.9rem;
        }

        .activity-text {
            flex: 1;
        }

        .activity-badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-left: 10px;
        }

        .badge-success {
            background: rgba(0,210,75,0.1);
            color: var(--success);
        }

        .badge-danger {
            background: rgba(255,71,87,0.1);
            color: var(--danger);
        }

        .badge-warning {
            background: rgba(255,170,0,0.1);
            color: var(--warning);
        }

        .footer {
            text-align: center;
            padding: 30px 0;
            color: var(--footer-color);
            border-top: 1px solid var(--border-color);
            margin-top: 50px;
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 25px;
            border-radius: 30px;
            background: white;
            box-shadow: var(--shadow-lg);
            border-left: 5px solid;
            animation: slideIn 0.3s;
            z-index: 9999;
        }
        .notification.success { border-color: var(--success); background: #d4edda; color: #155724; }
        .notification.error { border-color: var(--danger); background: #f8d7da; color: #721c24; }
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0%); opacity: 1; }
        }

        @media (max-width: 700px) {
            .header {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <% if (success) { %><div class="notification success"><%= success %></div><% } %>
    <% if (error) { %><div class="notification error"><%= error %></div><% } %>

    <header class="header">
        <div class="logo">
            <img src="/images/logo.jpg" alt="Resistance Logo">
            <h2>Resistance Admin</h2>
        </div>
        <div class="user-info">
            <span><%= user.username %></span>
            <button id="theme-toggle" class="theme-toggle">🌙</button>
            <a href="/admin/logout" class="btn-logout">Выйти</a>
        </div>
    </header>

    <div class="container">
        <h1>Админ-панель</h1>

        <!-- Статистика -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">👥</div>
                <h3>Участников клана</h3>
                <div class="stat-value"><%= stats.clan_members %></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🎭</div>
                <h3>RolePlay игроков</h3>
                <div class="stat-value"><%= stats.rp_players %></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🛡️</div>
                <h3>Персонал</h3>
                <div class="stat-value"><%= stats.staff %></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🏠</div>
                <h3>Имущества</h3>
                <div class="stat-value"><%= stats.properties %></div>
            </div>
        </div>

        <!-- НОВЫЕ БЫСТРЫЕ ДЕЙСТВИЯ -->
        <div class="actions-section">
            <h2 class="section-title">⚡ Быстрые действия</h2>
            
            <!-- Основные действия -->
            <div class="action-cards">
                <a href="/admin/db/clan_members/new" class="action-card">
                    <div class="action-icon">➕</div>
                    <div class="action-title">Добавить игрока</div>
                    <div class="action-desc">Новый участник клана</div>
                </a>
                <a href="/admin/db/properties/new" class="action-card">
                    <div class="action-icon">🏘️</div>
                    <div class="action-title">Добавить имущество</div>
                    <div class="action-desc">Недвижимость в городе</div>
                </a>
                <a href="/admin/db/structure_members/new" class="action-card info">
                    <div class="action-icon">👔</div>
                    <div class="action-title">Назначить в структуру</div>
                    <div class="action-desc">Полиция, армия и т.д.</div>
                </a>
                <a href="/admin/console" class="action-card warning">
                    <div class="action-icon">📝</div>
                    <div class="action-title">Открыть консоль</div>
                    <div class="action-desc">Команды и логи бота</div>
                </a>
            </div>

            <!-- Административные действия -->
            <div class="action-cards">
                <a href="/admin/settings" class="action-card info">
                    <div class="action-icon">⚙️</div>
                    <div class="action-title">Настройки</div>
                    <div class="action-desc">Конфигурация бота</div>
                </a>
                <a href="/admin/db" class="action-card">
                    <div class="action-icon">🗄️</div>
                    <div class="action-title">База данных</div>
                    <div class="action-desc">Управление таблицами</div>
                </a>
                <a href="#" class="action-card danger" id="restartBotBtn">
                    <div class="action-icon">🔄</div>
                    <div class="action-title">Перезапустить бота</div>
                    <div class="action-desc">Требуется подтверждение</div>
                </a>
                <a href="#" class="action-card warning" id="clearCacheBtn">
                    <div class="action-icon">🧹</div>
                    <div class="action-title">Очистить кэш</div>
                    <div class="action-desc">Освободить память</div>
                </a>
            </div>

            <!-- Быстрая статистика -->
            <div class="quick-stats">
                <div class="quick-stat">
                    <div class="quick-stat-icon">📊</div>
                    <div class="quick-stat-info">
                        <h4>За сегодня</h4>
                        <span><%= stats.today_joins || 0 %></span>
                    </div>
                </div>
                <div class="quick-stat">
                    <div class="quick-stat-icon">💬</div>
                    <div class="quick-stat-info">
                        <h4>Сообщений</h4>
                        <span><%= stats.today_messages || 0 %></span>
                    </div>
                </div>
                <div class="quick-stat">
                    <div class="quick-stat-icon">⚔️</div>
                    <div class="quick-stat-info">
                        <h4>PvP сегодня</h4>
                        <span><%= stats.today_pvp || 0 %></span>
                    </div>
                </div>
                <div class="quick-stat">
                    <div class="quick-stat-icon">💰</div>
                    <div class="quick-stat-info">
                        <h4>Транзакций</h4>
                        <span><%= stats.today_transactions || 0 %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Последние действия (убраны, так как recentActivities не передаётся) -->
        <!-- Временно скрываем этот блок до исправления -->

        <!-- Состояние бота -->
        <div style="display: flex; gap: 20px; justify-content: center; margin-bottom: 30px;">
            <div style="background: var(--card-bg); border-radius: 20px; padding: 15px 25px; border: 1px solid var(--border-color);">
                <span style="color: var(--footer-color);">Статус бота:</span>
                <span style="color: var(--success); font-weight: 600; margin-left: 10px;">● Активен</span>
            </div>
            <div style="background: var(--card-bg); border-radius: 20px; padding: 15px 25px; border: 1px solid var(--border-color);">
                <span style="color: var(--footer-color);">Последний PayDay:</span>
                <span style="color: var(--primary); font-weight: 600; margin-left: 10px;"><%= lastPayday || 'Не проводился' %></span>
            </div>
        </div>
    </div>

    <footer class="footer">
        <p>Resistance City Project • 2026</p>
    </footer>

    <script>
        (function() {
            // === Переключение темы ===
            const toggle = document.getElementById('theme-toggle');
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                toggle.textContent = '☀️';
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
                toggle.textContent = '🌙';
            }
            toggle.onclick = function() {
                const current = document.documentElement.getAttribute('data-theme');
                const newTheme = current === 'light' ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                toggle.textContent = newTheme === 'light' ? '🌙' : '☀️';
            };

            // === Перезапуск бота ===
            const restartBtn = document.getElementById('restartBotBtn');
            if (restartBtn) {
                restartBtn.onclick = async function(e) {
                    e.preventDefault();
                    if (confirm('Вы уверены, что хотите перезапустить бота? Это может занять несколько секунд.')) {
                        try {
                            const res = await fetch('/admin/bot/restart', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await res.json();
                            if (data.success) {
                                alert('Бот перезапускается...');
                                setTimeout(() => location.reload(), 2000);
                            } else {
                                alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                            }
                        } catch (e) {
                            alert('Ошибка сети: ' + e.message);
                        }
                    }
                };
            }

            // === Очистка кэша ===
            const clearCacheBtn = document.getElementById('clearCacheBtn');
            if (clearCacheBtn) {
                clearCacheBtn.onclick = async function(e) {
                    e.preventDefault();
                    if (confirm('Очистить кэш? Это может временно замедлить работу при повторной загрузке.')) {
                        try {
                            const res = await fetch('/admin/cache/clear', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await res.json();
                            if (data.success) {
                                alert('Кэш очищен');
                                location.reload();
                            } else {
                                alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                            }
                        } catch (e) {
                            alert('Ошибка сети: ' + e.message);
                        }
                    }
                };
            }
// Очистка кэша
document.getElementById('clearCacheBtn').addEventListener('click', async function(e) {
    e.preventDefault();
    if (!confirm('Очистить кэш? Это может временно замедлить работу.')) return;
    
    try {
        const response = await fetch('/admin/cache/clear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        // Проверяем, что ответ - JSON
        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
            throw new Error('Сервер вернул не JSON. Возможно, страница входа или ошибка 404.');
        }
        
        const data = await response.json();
        
        if (data.success) {
            alert('✅ ' + (data.message || 'Кэш очищен'));
            location.reload();
        } else {
            alert('❌ Ошибка: ' + (data.error || 'Неизвестная ошибка'));
        }
    } catch (error) {
        console.error('Ошибка:', error);
        alert('❌ Ошибка сети: ' + error.message);
    }
});

    // Перезапуск бота
    document.getElementById('restartBotBtn').addEventListener('click', async function(e) {
        e.preventDefault();
        if (!confirm('Перезапустить бота? Это займёт несколько секунд.')) return;
        
        try {
            const response = await fetch('/admin/bot/restart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            
            const contentType = response.headers.get('content-type');
            if (!contentType || !contentType.includes('application/json')) {
                throw new Error('Сервер вернул не JSON. Возможно, страница входа или ошибка 404.');
            }
            
            const data = await response.json();
            
            if (data.success) {
                alert('✅ ' + (data.message || 'Бот перезапускается'));
                setTimeout(() => location.reload(), 2000);
            } else {
                alert('❌ Ошибка: ' + (data.error || 'Неизвестная ошибка'));
            }
        } catch (error) {
            console.error('Ошибка:', error);
            alert('❌ Ошибка сети: ' + error.message);
        }
    });
            // Скрытие уведомлений
            setTimeout(() => {
                document.querySelectorAll('.notification').forEach(el => el.remove());
            }, 5000);
        })();
    </script>
</body>
</html>