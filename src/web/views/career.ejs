<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Карьера в Resistance City — государственные структуры, зарплаты, ранги">
    <title><%= typeof title !== 'undefined' ? title : 'Карьера в Resistance' %> — Resistance City</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .org-section {
            margin-bottom: 40px;
            animation: fadeIn 0.5s ease forwards;
        }
        .org-section-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }
        .org-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--primary), var(--primary-lighter));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            flex-shrink: 0;
        }
        .org-info-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        .org-info-item {
            text-align: center;
            padding: 16px 12px;
            background: rgba(255,255,255,0.02);
            border-radius: 10px;
        }
        .org-info-value {
            font-size: 1.3rem;
            font-weight: 700;
        }
        .org-info-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 4px;
        }
        .ranks-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
        }
        .ranks-table thead th {
            padding: 14px 18px;
            text-align: left;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--border);
        }
        .ranks-table tbody td {
            padding: 12px 18px;
            border-bottom: 1px solid var(--border);
            font-size: 0.95rem;
        }
        .ranks-table tbody tr:hover {
            background: rgba(99,67,212,0.05);
        }
        .rank-name {
            font-weight: 600;
            color: var(--text-bright);
        }
        .rank-level {
            text-align: center;
        }
        .rank-category {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .rank-salary {
            font-weight: 700;
            color: var(--success);
            text-align: right;
        }
        .rank-count {
            font-weight: 600;
            color: var(--info);
            text-align: center;
        }
        .frozen-badge {
            display: inline-block;
            padding: 6px 14px;
            background: rgba(202,78,78,0.15);
            border: 1px solid var(--danger);
            border-radius: var(--radius-full);
            color: var(--danger);
            font-weight: 700;
            font-size: 0.85rem;
            margin-bottom: 12px;
        }
        @media (max-width: 768px) {
            .org-info-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <%- include('partials/header', { page: 'career' }) %>

    <div class="container" style="margin-top: 32px;">

        <!-- ЗАГОЛОВОК -->
        <div style="margin-bottom: 32px;">
            <h1 class="text-gradient" style="margin-bottom: 8px;">🏛️ Карьера в Resistance</h1>
            <p style="color: var(--text-secondary); font-size: 1.1rem; max-width: 800px; line-height: 1.8;">
                Выберите свой путь в Свободном Городе. Каждая государственная структура предлагает 
                уникальные возможности для роста, стабильную зарплату и продвижение по службе.
            </p>
        </div>

        <!-- СПИСОК ОРГАНИЗАЦИЙ -->
        <% if (typeof organizations !== 'undefined' && organizations && organizations.length > 0) { %>
            <% for (var o = 0; o < organizations.length; o++) { 
                var org = organizations[o];
                var orgIcons = {
                    'police': '🚔',
                    'army': '🛡️',
                    'hospital': '🏥',
                    'academy': '🎓',
                    'government': '🏛️'
                };
                var orgIcon = orgIcons[org.key] || '📌';
            %>
                <% 
    var frozenStyle = '';
    if (org.isFrozen) {
        frozenStyle = ' style="opacity: 0.6; border-color: var(--danger);"';
    }
%>
<div class="card org-section"<%- frozenStyle %>>
                    
                    <!-- ЗАГОЛОВОК ОРГАНИЗАЦИИ -->
                    <div class="org-section-header">
                        <div class="org-icon"><%= orgIcon %></div>
                        <div>
                            <h2 style="margin-bottom: 4px;"><%= org.name %></h2>
                            <% if (org.isFrozen) { %>
                                <span class="frozen-badge">⚠ ЗАМОРОЖЕНА</span>
                            <% } %>
                        </div>
                    </div>

                    <!-- ИНФОРМАЦИОННЫЕ КАРТОЧКИ -->
                    <div class="org-info-grid">
                        <div class="org-info-item">
                            <div class="org-info-value" style="color: var(--info);"><%= org.totalMembers %></div>
                            <div class="org-info-label">Сотрудников</div>
                        </div>
                        <div class="org-info-item">
                            <div class="org-info-value" style="color: var(--success);">
                                <%= org.budget >= 1000000 ? (org.budget / 1000000).toFixed(1) + 'M' : Math.floor(org.budget / 1000) + 'K' %> ₽
                            </div>
                            <div class="org-info-label">Бюджет</div>
                        </div>
                        <div class="org-info-item">
                            <div class="org-info-value" style="color: var(--warning);"><%= org.materials || 0 %></div>
                            <div class="org-info-label">Материалов</div>
                        </div>
                        <div class="org-info-item">
                            <div class="org-info-value" style="color: var(--primary-lighter);"><%= org.ranks ? org.ranks.length : 0 %></div>
                            <div class="org-info-label">Рангов</div>
                        </div>
                    </div>

                    <!-- ТАБЛИЦА РАНГОВ -->
                    <% if (org.ranks && org.ranks.length > 0) { %>
                        <div class="table-container">
                            <table class="ranks-table">
                                <thead>
                                    <tr>
                                        <th>Ранг</th>
                                        <th class="rank-level">Уровень</th>
                                        <th>Категория</th>
                                        <th class="rank-salary">Зарплата</th>
                                        <th class="rank-count">Сотрудников</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% for (var r = 0; r < org.ranks.length; r++) { 
                                        var rank = org.ranks[r];
                                        var catNames = {
                                            'junior': 'Младший состав',
                                            'middle': 'Средний состав',
                                            'senior': 'Старший состав',
                                            'command': 'Руководство'
                                        };
                                        var catName = catNames[rank.category] || rank.category || '—';
                                    %>
                                        <tr>
                                            <td class="rank-name"><%= rank.name %></td>
                                            <td class="rank-level">
                                                <span class="badge badge-info"><%= rank.level %></span>
                                            </td>
                                            <td class="rank-category"><%= catName %></td>
                                            <td class="rank-salary"><%= rank.salary.toLocaleString() %> ₽/час</td>
                                            <td class="rank-count"><%= rank.count || 0 %></td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <div class="card" style="text-align: center; padding: 60px 20px;">
                <div style="font-size: 3rem; margin-bottom: 12px;">📭</div>
                <h3>Нет данных об организациях</h3>
                <p style="color: var(--text-secondary);">Информация появится после настройки системы.</p>
            </div>
        <% } %>

        <!-- КАК ВСТУПИТЬ -->
        <div class="card" style="text-align: center; padding: 40px 32px; background: linear-gradient(135deg, rgba(99,67,212,0.15), rgba(170,78,255,0.08)); border-color: var(--primary); margin-top: 40px;">
            <h2 class="text-gradient" style="margin-bottom: 16px;">Как начать карьеру?</h2>
            <div style="max-width: 700px; margin: 0 auto 24px;">
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; text-align: center;">
                    <div>
                        <div style="font-size: 2rem; margin-bottom: 8px;">1️⃣</div>
                        <h4 style="margin-bottom: 4px;">Образование</h4>
                        <p style="color: var(--text-secondary); font-size: 0.85rem;">Получите образование в Академии</p>
                    </div>
                    <div>
                        <div style="font-size: 2rem; margin-bottom: 8px;">2️⃣</div>
                        <h4 style="margin-bottom: 4px;">Медкнижка</h4>
                        <p style="color: var(--text-secondary); font-size: 0.85rem;">Оформите в Больнице</p>
                    </div>
                    <div>
                        <div style="font-size: 2rem; margin-bottom: 8px;">3️⃣</div>
                        <h4 style="margin-bottom: 4px;">Заявление</h4>
                        <p style="color: var(--text-secondary); font-size: 0.85rem;">Подайте руководителю</p>
                    </div>
                    <div>
                        <div style="font-size: 2rem; margin-bottom: 8px;">4️⃣</div>
                        <h4 style="margin-bottom: 4px;">Служба</h4>
                        <p style="color: var(--text-secondary); font-size: 0.85rem;">Начните с низшего ранга</p>
                    </div>
                </div>
            </div>
            <a href="/top" class="btn btn-primary btn-lg">Посмотреть топ игроков</a>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>