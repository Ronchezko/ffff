<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Карьера в Resistance</title>
    <link rel="icon" type="image/png" href="/images/logo.jpg">
    <style>
        /* ===== ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ===== */
        :root {
            --bg-color: #f8faff;
            --text-color: #2d3748;
            --card-bg: rgba(255, 255, 255, 0.8);
            --card-bg-solid: #ffffff;
            --header-bg: rgba(255, 255, 255, 0.7);
            --border-color: rgba(203, 213, 224, 0.3);
            --primary: #6b46c1;
            --primary-light: #9f7aea;
            --primary-soft: #e9d8fd;
            --primary-hover: #553c9a;
            --secondary: #38a169;
            --secondary-light: #9ae6b4;
            --nav-link-color: #4a5568;
            --nav-link-hover: #6b46c1;
            --footer-color: #718096;
            --hero-overlay: rgba(255, 255, 255, 0.2);
            --hero-content-bg: rgba(255, 255, 255, 0.15);
            --gradient-1: linear-gradient(135deg, #e9d8fd 0%, #fed7d7 50%, #c6f6d5 100%);
            --gradient-2: linear-gradient(45deg, #9f7aea, #f687b3, #fbbf6e);
            --gradient-soft: linear-gradient(135deg, rgba(159, 122, 234, 0.1), rgba(246, 135, 179, 0.1), rgba(251, 191, 110, 0.1));
            --shadow-sm: 0 10px 30px rgba(107, 70, 193, 0.05);
            --shadow-md: 0 15px 40px rgba(107, 70, 193, 0.1);
            --shadow-lg: 0 20px 60px rgba(107, 70, 193, 0.15);
        }

        [data-theme="dark"] {
            --bg-color: #0f0f1a;
            --text-color: #e2e8f0;
            --card-bg: rgba(26, 32, 44, 0.8);
            --card-bg-solid: #1a202c;
            --header-bg: rgba(17, 17, 27, 0.8);
            --border-color: rgba(74, 85, 104, 0.3);
            --primary: #b794f4;
            --primary-light: #d6bcfa;
            --primary-soft: rgba(183, 148, 244, 0.15);
            --primary-hover: #9f7aea;
            --secondary: #68d391;
            --secondary-light: #c6f6d5;
            --nav-link-color: #cbd5e0;
            --nav-link-hover: #b794f4;
            --footer-color: #718096;
            --hero-overlay: rgba(0, 0, 0, 0.3);
            --hero-content-bg: rgba(26, 32, 44, 0.3);
            --gradient-1: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1f1f3a 100%);
            --gradient-2: linear-gradient(45deg, #b794f4, #f687b3, #fbbf6e);
            --gradient-soft: linear-gradient(135deg, rgba(183, 148, 244, 0.1), rgba(246, 135, 179, 0.1), rgba(251, 191, 110, 0.1));
            --shadow-sm: 0 10px 30px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 15px 40px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            transition: background-color 0.5s ease, color 0.3s ease;
            overflow-x: hidden;
            position: relative;
            min-height: 100vh;
        }

        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        /* ===== АНИМИРОВАННЫЙ ГРАДИЕНТНЫЙ ФОН ===== */
        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient-1);
            background-size: 300% 300%;
            animation: gradientShift 15s ease infinite;
            z-index: -2;
            opacity: 0.8;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* ===== АНИМИРОВАННЫЕ MINECRAFT-ПЕРСОНАЖИ ===== */
        .minecraft-characters {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .character {
            position: absolute;
            width: 60px;
            height: 60px;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.2));
            opacity: 0.6;
            animation: characterFloat 20s infinite ease-in-out;
        }

        .character img {
            width: 100%;
            height: 100%;
            image-rendering: pixelated;
        }

        .character-1 { top: 15%; left: 5%; animation-duration: 25s; }
        .character-2 { bottom: 20%; right: 8%; animation-duration: 30s; animation-direction: reverse; }
        .character-3 { top: 60%; left: 10%; animation-duration: 22s; animation-delay: 2s; }
        .character-4 { top: 30%; right: 15%; animation-duration: 28s; animation-delay: 1s; }
        .character-5 { bottom: 10%; left: 20%; animation-duration: 24s; animation-delay: 3s; }

        @keyframes characterFloat {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            25% { transform: translateY(-20px) rotate(2deg); }
            50% { transform: translateY(0) rotate(0deg); }
            75% { transform: translateY(20px) rotate(-2deg); }
        }

        /* ===== ПЛАВАЮЩИЕ КУБИКИ ===== */
        .floating-cubes {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .cube {
            position: absolute;
            width: 30px;
            height: 30px;
            background: var(--primary-soft);
            border: 2px solid var(--primary);
            transform: rotate(45deg);
            animation: cubeFloat 15s infinite;
            opacity: 0.2;
        }

        .cube-1 { top: 10%; left: 10%; animation-duration: 20s; }
        .cube-2 { top: 70%; right: 15%; animation-duration: 18s; }
        .cube-3 { bottom: 20%; left: 20%; animation-duration: 22s; }
        .cube-4 { top: 40%; right: 25%; animation-duration: 16s; }

        @keyframes cubeFloat {
            0%, 100% { transform: rotate(45deg) translateY(0); }
            50% { transform: rotate(45deg) translateY(-30px) scale(1.1); }
        }

        /* ===== ШАПКА ===== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background: var(--header-bg);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 60px;
            width: auto;
            border-radius: 15px;
            filter: drop-shadow(0 0 20px rgba(107, 70, 193, 0.3));
        }

        .logo h2 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #6b46c1, #9f7aea, #f687b3);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ===== ЦЕНТРАЛЬНОЕ МЕНЮ НАВИГАЦИИ ===== */
        .nav {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        flex: 1;
    }
        .nav-center {
            flex: 1;
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .nav-center a {
            color: var(--nav-link-color);
            text-decoration: none;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 40px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .nav-center a::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .nav-center a:hover::before {
            left: 100%;
        }

        .nav-center a:hover {
            background: var(--primary-soft);
            color: var(--primary);
            transform: translateY(-2px);
        }

        .nav-center a.active {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: white;
            box-shadow: 0 10px 25px -5px var(--primary);
        }

        /* ===== ПРАВАЯ ЧАСТЬ ШАПКИ ===== */
        .header-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .theme-toggle {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            cursor: pointer;
            padding: 8px;
            border-radius: 40px;
            width: 70px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            transition: all 0.3s;
            box-shadow: var(--shadow-sm);
        }

        .theme-toggle:hover {
            transform: scale(1.05);
            box-shadow: var(--shadow-md);
        }

        .theme-toggle .sun, .theme-toggle .moon {
            width: 24px;
            height: 24px;
            transition: all 0.3s;
            z-index: 2;
        }

        .theme-toggle .sun { color: #fbbf6e; }
        .theme-toggle .moon { color: #b794f4; }

        .theme-toggle::after {
            content: '';
            position: absolute;
            width: 32px;
            height: 32px;
            background: white;
            border-radius: 50%;
            left: 4px;
            transition: transform 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            z-index: 1;
        }

        [data-theme="dark"] .theme-toggle::after {
            transform: translateX(30px);
        }

        .btn-discord {
            background: linear-gradient(135deg, #6b46c1, #9f7aea);
            padding: 10px 25px;
            border-radius: 40px;
            color: white !important;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 10px 20px -5px rgba(107, 70, 193, 0.3);
            text-decoration: none;
        }

        .btn-discord:hover {
            background: linear-gradient(135deg, #553c9a, #805ad5);
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(107, 70, 193, 0.4);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
            background: var(--card-bg);
            padding: 8px 20px;
            border-radius: 40px;
            border: 1px solid var(--border-color);
            backdrop-filter: blur(10px);
            text-decoration: none;
            color: var(--text-color);
            transition: all 0.3s;
        }

        .user-info:hover {
            background: var(--primary-soft);
            transform: translateY(-2px);
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary);
        }

        .logout-btn {
            color: #ff4757;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 40px;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            background: rgba(255, 71, 87, 0.1);
        }

        /* ===== ВЕРХНИЕ КНОПКИ ===== */
        .top-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin: 40px 0 60px;
            flex-wrap: wrap;
        }

        .top-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 15px 30px;
            border-radius: 40px;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            color: var(--text-color);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: var(--shadow-sm);
        }

        .top-btn:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .top-btn.discord { background: linear-gradient(135deg, #5865f2, #4752c4); color: white; }
        .top-btn.telegram { background: linear-gradient(135deg, #229ed9, #1b85b8); color: white; }
        .top-btn.donate { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #1a202c; }

        /* ===== HERO СЕКЦИЯ ===== */
        .career-hero {
            position: relative;
            min-height: 50vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            margin-bottom: 80px;
            z-index: 1;
        }

        .hero-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(var(--hero-overlay), var(--hero-overlay)), url('/images/fon.png') center/cover no-repeat;
            filter: brightness(0.7);
            z-index: -1;
        }

        .hero-content {
            max-width: 900px;
            padding: 60px;
            background: var(--hero-content-bg);
            backdrop-filter: blur(20px);
            border-radius: 50px;
            border: 1px solid rgba(255,255,255,0.2);
            animation: floatHero 6s ease-in-out infinite;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
        }

        @keyframes floatHero {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        .hero-content h1 {
            font-size: clamp(3rem, 6vw, 5rem);
            font-weight: 800;
            background: linear-gradient(135deg, #fff, #e2e8f0, #cbd5e0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 0 30px rgba(255,255,255,0.3));
            margin-bottom: 20px;
        }

        .hero-content p {
            font-size: 1.5rem;
            color: rgba(255, 255, 255, 0.95);
            font-weight: 300;
            margin-bottom: 30px;
        }

        .hero-badges {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .hero-badge {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(5px);
            padding: 10px 25px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            border: 1px solid rgba(255,255,255,0.3);
            transition: all 0.3s;
        }

        .hero-badge:hover {
            background: var(--primary);
            transform: translateY(-5px);
        }

        /* ===== ОСНОВНОЙ КОНТЕЙНЕР ===== */
        .container {
            max-width: 1400px;
            margin: 0 auto 80px;
            padding: 0 20px;
            position: relative;
            z-index: 2;
        }

        .fade-up {
            opacity: 0;
            transform: translateY(50px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .section {
            margin-bottom: 100px;
        }

        .section-title {
            font-size: 2.5rem;
            margin-bottom: 40px;
            position: relative;
            display: inline-block;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            border-radius: 2px;
        }

        .info-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            padding: 50px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-color);
            position: relative;
            overflow: hidden;
        }

        .info-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: var(--gradient-soft);
            animation: rotate 20s linear infinite;
            z-index: 0;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .info-card > * {
            position: relative;
            z-index: 1;
        }

        .info-card h3 {
            font-size: 2rem;
            margin: 30px 0 20px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }

        .feature-item {
            background: var(--primary-soft);
            padding: 25px;
            border-radius: 30px;
            transition: all 0.3s;
            border: 1px solid var(--border-color);
        }

        .feature-item:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: var(--shadow-lg);
            background: var(--card-bg-solid);
        }

        .feature-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 15px;
        }

        .feature-item strong {
            font-size: 1.2rem;
            color: var(--primary);
            display: block;
            margin-bottom: 10px;
        }

        .gov-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 30px 0;
        }

        .gov-item {
            background: var(--gradient-soft);
            padding: 20px;
            border-radius: 20px;
            transition: all 0.3s;
        }

        .gov-item:hover {
            transform: translateX(10px);
            background: linear-gradient(135deg, var(--primary-soft), var(--card-bg));
        }

        .gov-item span {
            font-weight: 700;
            color: var(--primary);
        }

        .reasons-list {
            list-style: none;
            margin: 30px 0;
        }

        .reasons-list li {
            padding: 15px 0;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 1.1rem;
            transition: all 0.3s;
        }

        .reasons-list li:hover {
            transform: translateX(10px);
            color: var(--primary);
        }

        /* ===== FAQ АККОРДЕОН ===== */
        .faq-grid {
            display: grid;
            gap: 20px;
        }

        .faq-item {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            transition: all 0.3s;
        }

        .faq-item:hover {
            transform: translateX(10px);
            box-shadow: var(--shadow-lg);
        }

        .faq-question {
            padding: 25px 30px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            font-size: 1.2rem;
            background: var(--gradient-soft);
            transition: all 0.3s;
        }

        .faq-question:hover {
            background: var(--primary-soft);
        }

        .faq-question .arrow {
            transition: transform 0.3s;
            font-size: 1.5rem;
            color: var(--primary);
        }

        .faq-item.open .faq-question .arrow {
            transform: rotate(180deg);
        }

        .faq-answer {
            max-height: 0;
            padding: 0 30px;
            overflow: hidden;
            transition: max-height 0.5s ease, padding 0.5s ease;
            background: var(--card-bg);
            color: var(--text-color);
            font-size: 1rem;
            line-height: 1.8;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
            padding: 20px 30px;
            border-top: 1px solid var(--border-color);
        }

        .faq-answer ul {
            margin: 10px 0 10px 20px;
        }

        /* ===== КОНСТИТУЦИЯ ===== */
        .constitution-section {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            padding: 50px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-color);
            position: relative;
            overflow: hidden;
        }

        .constitution-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(45deg, transparent, transparent 20px, var(--primary-soft) 20px, var(--primary-soft) 40px);
            opacity: 0.1;
            pointer-events: none;
        }

        .constitution-section h3 {
            font-size: 1.8rem;
            margin: 30px 0 20px;
            color: var(--primary);
        }

        .constitution-section h4 {
            font-size: 1.3rem;
            margin: 25px 0 15px;
            color: var(--secondary);
        }

        .law-number {
            font-weight: 700;
            color: var(--primary);
            display: inline-block;
            margin-right: 10px;
            font-size: 1.1rem;
        }

        .commands-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .command-item {
            background: var(--primary-soft);
            padding: 15px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
            transition: all 0.3s;
        }

        .command-item:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-md);
            background: var(--card-bg-solid);
        }

        .command-item code {
            color: var(--primary);
            font-weight: 600;
            font-size: 1.1rem;
        }

        /* ===== КНОПКА "НАВЕРХ" ===== */
        .scroll-top {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.4s;
            z-index: 99;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .scroll-top.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .scroll-top:hover {
            transform: scale(1.15) rotate(360deg);
            box-shadow: 0 20px 40px rgba(107, 70, 193, 0.5);
        }

        /* ===== ФУТЕР ===== */
        .footer {
            text-align: center;
            padding: 60px 0;
            background: var(--header-bg);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--border-color);
            color: var(--footer-color);
            font-size: 1rem;
            position: relative;
            z-index: 2;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--footer-color);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: var(--primary);
        }

        .footer-social {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 30px 0;
        }

        .social-icon {
            width: 50px;
            height: 50px;
            background: var(--primary-soft);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            color: var(--primary);
            font-size: 1.5rem;
            text-decoration: none;
        }

        .social-icon:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-5px);
        }

        @media (max-width: 900px) {
            .header {
                flex-direction: column;
                gap: 20px;
            }
            .nav-center {
                order: 2;
                width: 100%;
            }
            .logo {
                order: 1;
            }
            .header-right {
                order: 3;
            }
            .hero-content h1 { font-size: 3rem; }
            .hero-content p { font-size: 1.2rem; }
            .section-title { font-size: 2rem; }
            .info-card { padding: 30px; }
        }

        @media (max-width: 600px) {
            .top-buttons { flex-direction: column; align-items: stretch; }
            .feature-grid, .gov-grid, .commands-grid { grid-template-columns: 1fr; }
            .hero-content { padding: 30px; }
        }
    </style>
</head>
