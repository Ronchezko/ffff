<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Рейтинг игроков Resistance City">
    <title><%= typeof title !== 'undefined' ? title : 'Топ игроков' %> — Resistance City</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .top-tabs {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 24px;
            padding: 12px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }
        .top-tabs .tab-btn {
            padding: 10px 18px;
            border-radius: var(--radius-md);
            border: 2px solid transparent;
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-block;
        }
        .top-tabs .tab-btn:hover {
            background: rgba(99,67,212,0.1);
            border-color: var(--border);
            color: var(--text-bright);
            text-decoration: none;
        }
        .top-tabs .tab-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        .top-table {
            width: 100%;
            border-collapse: collapse;
        }
        .top-table thead th {
            padding: 16px 20px;
            text-align: left;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
        }
        .top-table tbody td {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 0.95rem;
        }
        .top-table tbody tr {
            transition: all 0.15s ease;
        }
        .top-table tbody tr:hover {
            background: rgba(99,67,212,0.05);
        }
        .top-table tbody tr:nth-child(even) {
            background: rgba(255,255,255,0.01);
        }
        .top-table tbody tr:nth-child(even):hover {
            background: rgba(99,67,212,0.08);
        }
        .top-table .position-cell {
            width: 60px;
            text-align: center;
            font-weight: 700;
            font-size: 1.1rem;
        }
        .top-table .player-cell {
            font-weight: 600;
            min-width: 150px;
        }
        .top-table .player-cell a {
            color: var(--text-bright);
            text-decoration: none;
            transition: color 0.15s ease;
        }
        .top-table .player-cell a:hover {
            color: var(--primary-lighter);
            text-decoration: underline;
        }
        .top-table .value-cell {
            font-weight: 700;
            text-align: right;
            min-width: 100px;
        }
        .pagination-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            margin-top: 24px;
            flex-wrap: wrap;
        }
        .pagination-wrapper a,
        .pagination-wrapper span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 40px;
            height: 40px;
            padding: 0 12px;
            border-radius: var(--radius-sm);
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-primary);
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.15s ease;
        }
        .pagination-wrapper a:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
            text-decoration: none;
        }
        .pagination-wrapper .active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
            font-weight: 700;
        }
        .pagination-wrapper .disabled {
            opacity: 0.4;
            pointer-events: none;
        }
        .pagination-info {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 8px;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }
        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }
    </style>
</head>
<body>
    <%- include('partials/header', { page: 'top' }) %>

    <div class="container" style="margin-top: 32px;">

        <!-- ЗАГОЛОВОК -->
        <div style="margin-bottom: 24px;">
            <h1 class="text-gradient" style="margin-bottom: 4px;">🏆 <%= typeof title !== 'undefined' ? title : 'Рейтинг игроков' %></h1>
            <p style="color: var(--text-secondary);">
                Лучшие игроки Resistance City
            </p>
        </div>

        <!-- ТАБЫ -->
        <div class="top-tabs">
            <a href="/top?type=balance" class="tab-btn <% if (typeof type !== 'undefined' && type === 'balance') { %>active<% } %>">
                💰 Баланс
            </a>
            <a href="/top?type=kills" class="tab-btn <% if (typeof type !== 'undefined' && type === 'kills') { %>active<% } %>">
                ⚔️ Убийства
            </a>
            <a href="/top?type=hours" class="tab-btn <% if (typeof type !== 'undefined' && type === 'hours') { %>active<% } %>">
                ⏰ Часы в RP
            </a>
            <a href="/top?type=payday" class="tab-btn <% if (typeof type !== 'undefined' && type === 'payday') { %>active<% } %>">
                💵 PayDay
            </a>
            <a href="/top?type=properties" class="tab-btn <% if (typeof type !== 'undefined' && type === 'properties') { %>active<% } %>">
                🏠 Имущество
            </a>
        </div>

        <!-- ТАБЛИЦА -->
        <div class="card animate-on-scroll">
            <div class="table-container">
                <table class="top-table">
                    <thead>
                        <tr>
                            <th class="position-cell">#</th>
                            <th class="player-cell">Игрок</th>
                            <% if (typeof type !== 'undefined') { %>
                                <% if (type === 'balance') { %>
                                    <th class="value-cell">Баланс</th>
                                <% } else if (type === 'kills') { %>
                                    <th class="value-cell">Убийств</th>
                                    <th class="value-cell">Смертей</th>
                                    <th class="value-cell">K/D</th>
                                <% } else if (type === 'hours') { %>
                                    <th class="value-cell">Часов в RP</th>
                                    <th class="value-cell">PayDay'ев</th>
                                <% } else if (type === 'payday') { %>
                                    <th class="value-cell">PayDay'ев</th>
                                    <th class="value-cell">Часов в RP</th>
                                <% } else if (type === 'properties') { %>
                                    <th class="value-cell">Количество</th>
                                <% } else { %>
                                    <th class="value-cell">Значение</th>
                                <% } %>
                            <% } else { %>
                                <th class="value-cell">Баланс</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof results !== 'undefined' && results && results.length > 0) { %>
                            <% for (var i = 0; i < results.length; i++) { 
                                var player = results[i];
                                var position = (typeof pagination !== 'undefined' && pagination ? (pagination.page - 1) * pagination.perPage : 0) + i + 1;
                                var medal = '';
                                if (position === 1) medal = '🥇';
                                else if (position === 2) medal = '🥈';
                                else if (position === 3) medal = '🥉';
                            %>
                                <tr>
                                    <td class="position-cell">
                                        <% if (medal) { %>
                                            <span style="font-size: 1.5rem;"><%= medal %></span>
                                        <% } else { %>
                                            <span style="color: var(--text-muted);"><%= position %></span>
                                        <% } %>
                                    </td>
                                    <td class="player-cell">
                                        <a href="/profile/<%= player.username %>">
                                            <%= player.username %>
                                        </a>
                                    </td>
                                    <% if (typeof type !== 'undefined') { %>
                                        <% if (type === 'balance') { %>
                                            <td class="value-cell" style="color: var(--success);">
                                                <%= (player.balance || 0).toLocaleString() %> ₽
                                            </td>
                                        <% } else if (type === 'kills') { %>
                                            <td class="value-cell" style="color: var(--danger);">
                                                <%= player.kills || 0 %>
                                            </td>
                                            <td class="value-cell" style="color: var(--warning);">
                                                <%= player.deaths || 0 %>
                                            </td>
                                            <td class="value-cell" style="color: var(--info);">
                                                <%= player.deaths > 0 ? (player.kills / player.deaths).toFixed(2) : (player.kills || 0) %>
                                            </td>
                                        <% } else if (type === 'hours') { %>
                                            <td class="value-cell" style="color: var(--info);">
                                                <%= (player.total_hours || 0).toFixed(1) %> ч
                                            </td>
                                            <td class="value-cell" style="color: var(--primary-lighter);">
                                                <%= player.payday_count || 0 %>
                                            </td>
                                        <% } else if (type === 'payday') { %>
                                            <td class="value-cell" style="color: var(--primary-lighter);">
                                                <%= player.payday_count || 0 %>
                                            </td>
                                            <td class="value-cell" style="color: var(--info);">
                                                <%= (player.total_hours || 0).toFixed(1) %> ч
                                            </td>
                                        <% } else if (type === 'properties') { %>
                                            <td class="value-cell" style="color: var(--info);">
                                                <%= player.property_count || 0 %>
                                            </td>
                                        <% } else { %>
                                            <td class="value-cell" style="color: var(--success);">
                                                <%= (player.balance || 0).toLocaleString() %> ₽
                                            </td>
                                        <% } %>
                                    <% } else { %>
                                        <td class="value-cell" style="color: var(--success);">
                                            <%= (player.balance || 0).toLocaleString() %> ₽
                                        </td>
                                    <% } %>
                                </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="10">
                                    <div class="empty-state">
                                        <div class="empty-state-icon">
                                            <% if (typeof type !== 'undefined' && type === 'kills') { %>
                                                🕊️
                                            <% } else if (typeof type !== 'undefined' && type === 'balance') { %>
                                                💸
                                            <% } else if (typeof type !== 'undefined' && type === 'hours') { %>
                                                ⏰
                                            <% } else if (typeof type !== 'undefined' && type === 'payday') { %>
                                                💵
                                            <% } else if (typeof type !== 'undefined' && type === 'properties') { %>
                                                🏠
                                            <% } else { %>
                                                📭
                                            <% } %>
                                        </div>
                                        <p style="font-size: 1.1rem; font-weight: 600;">Нет данных для отображения</p>
                                        <p style="font-size: 0.9rem;">Данные появятся после активности игроков</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- ПАГИНАЦИЯ -->
            <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
                <div class="pagination-wrapper">
                    <% if (pagination.page > 1) { %>
                        <a href="/top?type=<%= typeof type !== 'undefined' ? type : 'balance' %>&page=<%= pagination.page - 1 %>">
                            ← Назад
                        </a>
                    <% } else { %>
                        <span class="disabled">← Назад</span>
                    <% } %>

                    <% 
                        var startPage = Math.max(1, pagination.page - 2);
                        var endPage = Math.min(pagination.totalPages, pagination.page + 2);
                        for (var p = startPage; p <= endPage; p++) {
                    %>
                        <a href="/top?type=<%= typeof type !== 'undefined' ? type : 'balance' %>&page=<%= p %>"
                           class="<%= p === pagination.page ? 'active' : '' %>">
                            <%= p %>
                        </a>
                    <% } %>

                    <% if (pagination.page < pagination.totalPages) { %>
                        <a href="/top?type=<%= typeof type !== 'undefined' ? type : 'balance' %>&page=<%= pagination.page + 1 %>">
                            Вперёд →
                        </a>
                    <% } else { %>
                        <span class="disabled">Вперёд →</span>
                    <% } %>
                </div>
                <div class="pagination-info">
                    Показаны записи <%= (pagination.page - 1) * pagination.perPage + 1 %>–<%= Math.min(pagination.page * pagination.perPage, pagination.totalCount) %> из <%= pagination.totalCount %>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>