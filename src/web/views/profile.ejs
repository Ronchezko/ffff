<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Resistance</title>
    <link rel="icon" type="image/png" href="/images/logo.jpg">
    <style>
        /* ===== ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ===== */
        :root {
            --bg-color: #f8faff;
            --text-color: #2d3748;
            --card-bg: rgba(255, 255, 255, 0.95);
            --card-bg-solid: #ffffff;
            --header-bg: rgba(255, 255, 255, 0.95);
            --border-color: rgba(0, 0, 0, 0.08);
            --primary: #000000;
            --primary-light: #2d2d2d;
            --primary-soft: rgba(0, 0, 0, 0.05);
            --primary-hover: #1a1a1a;
            --secondary: #4a5568;
            --nav-link-color: #4a5568;
            --nav-link-hover: #000000;
            --footer-color: #718096;
            --hero-overlay: rgba(0, 0, 0, 0.1);
            --hero-content-bg: rgba(255, 255, 255, 0.9);
            --gradient-1: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 50%, #ffffff 100%);
            --gradient-2: linear-gradient(45deg, #2d2d2d, #1a1a1a, #000000);
            --gradient-soft: linear-gradient(135deg, rgba(0, 0, 0, 0.03), rgba(0, 0, 0, 0.05));
            --shadow-sm: 0 10px 30px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 15px 40px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.12);
        }

        [data-theme="dark"] {
            --bg-color: #0f0f1a;
            --text-color: #e2e8f0;
            --card-bg: rgba(26, 32, 44, 0.95);
            --card-bg-solid: #1a202c;
            --header-bg: rgba(17, 17, 27, 0.95);
            --border-color: rgba(74, 85, 104, 0.3);
            --primary: #b794f4;
            --primary-light: #d6bcfa;
            --primary-soft: rgba(183, 148, 244, 0.15);
            --primary-hover: #9f7aea;
            --secondary: #68d391;
            --nav-link-color: #cbd5e0;
            --nav-link-hover: #b794f4;
            --footer-color: #718096;
            --hero-overlay: rgba(0, 0, 0, 0.3);
            --hero-content-bg: rgba(26, 32, 44, 0.9);
            --gradient-1: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1f1f3a 100%);
            --gradient-2: linear-gradient(45deg, #b794f4, #f687b3, #fbbf6e);
            --gradient-soft: linear-gradient(135deg, rgba(183, 148, 244, 0.1), rgba(246, 135, 179, 0.1), rgba(251, 191, 110, 0.1));
            --shadow-sm: 0 10px 30px rgba(0, 0, 0, 0.3);
            --shadow-md: 0 15px 40px rgba(0, 0, 0, 0.4);
            --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            transition: background-color 0.5s ease, color 0.3s ease;
            overflow-x: hidden;
            position: relative;
            min-height: 100vh;
        }

        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        /* ===== АНИМИРОВАННЫЙ ФОН ===== */
        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient-1);
            background-size: 300% 300%;
            animation: gradientShift 15s ease infinite;
            z-index: -2;
            opacity: 0.8;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* ===== АНИМИРОВАННЫЕ MINECRAFT-ПЕРСОНАЖИ ===== */
        .minecraft-characters {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .character {
            position: absolute;
            width: 60px;
            height: 60px;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.2));
            opacity: 0.5;
            animation: characterFloat 20s infinite ease-in-out;
        }

        .character img {
            width: 100%;
            height: 100%;
            image-rendering: pixelated;
        }

        .character-1 { top: 15%; left: 5%; animation-duration: 25s; }
        .character-2 { bottom: 20%; right: 8%; animation-duration: 30s; animation-direction: reverse; }
        .character-3 { top: 60%; left: 10%; animation-duration: 22s; animation-delay: 2s; }
        .character-4 { top: 30%; right: 15%; animation-duration: 28s; animation-delay: 1s; }
        .character-5 { bottom: 10%; left: 20%; animation-duration: 24s; animation-delay: 3s; }

        @keyframes characterFloat {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            25% { transform: translateY(-20px) rotate(2deg); }
            50% { transform: translateY(0) rotate(0deg); }
            75% { transform: translateY(20px) rotate(-2deg); }
        }

        /* ===== ПЛАВАЮЩИЕ КУБИКИ ===== */
        .floating-cubes {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .cube {
            position: absolute;
            width: 30px;
            height: 30px;
            background: var(--primary-soft);
            border: 2px solid var(--primary);
            transform: rotate(45deg);
            animation: cubeFloat 15s infinite;
            opacity: 0.15;
        }

        .cube-1 { top: 10%; left: 10%; animation-duration: 20s; }
        .cube-2 { top: 70%; right: 15%; animation-duration: 18s; }
        .cube-3 { bottom: 20%; left: 20%; animation-duration: 22s; }
        .cube-4 { top: 40%; right: 25%; animation-duration: 16s; }

        @keyframes cubeFloat {
            0%, 100% { transform: rotate(45deg) translateY(0); }
            50% { transform: rotate(45deg) translateY(-30px) scale(1.1); }
        }

        /* ===== ШАПКА ===== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background: var(--header-bg);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            height: 60px;
            border-radius: 15px;
            filter: drop-shadow(0 0 20px rgba(0, 0, 0, 0.1));
        }

        .logo h2 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #000000, #4a5568);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        /* ===== ЦЕНТРАЛЬНОЕ МЕНЮ НАВИГАЦИИ ===== */
        .nav {
    display: flex;
    gap: 15px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    flex: 1;
}
        .nav-center {
            flex: 1;
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .nav-center a {
            color: var(--nav-link-color);
            text-decoration: none;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 40px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .nav-center a::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.1), transparent);
            transition: left 0.5s;
        }

        .nav-center a:hover::before {
            left: 100%;
        }

        .nav-center a:hover {
            background: var(--primary-soft);
            color: var(--primary);
            transform: translateY(-2px);
        }

        .nav-center a.active {
            background: var(--gradient-2);
            color: white;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }

        /* ===== ПРАВАЯ ЧАСТЬ ШАПКИ ===== */
        .header-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .theme-toggle {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            cursor: pointer;
            padding: 8px;
            border-radius: 40px;
            width: 70px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            transition: all 0.3s;
            box-shadow: var(--shadow-sm);
        }

        .theme-toggle:hover {
            transform: scale(1.05);
            box-shadow: var(--shadow-md);
        }

        .theme-toggle .sun, .theme-toggle .moon {
            width: 24px;
            height: 24px;
            transition: all 0.3s;
            z-index: 2;
        }

        .theme-toggle .sun { color: #fbbf6e; }
        .theme-toggle .moon { color: #b794f4; }

        .theme-toggle::after {
            content: '';
            position: absolute;
            width: 32px;
            height: 32px;
            background: white;
            border-radius: 50%;
            left: 4px;
            transition: transform 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            z-index: 1;
        }

        [data-theme="dark"] .theme-toggle::after {
            transform: translateX(30px);
        }

        .btn-discord {
            background: linear-gradient(135deg, #5865f2, #4752c4);
            padding: 10px 25px;
            border-radius: 40px;
            color: white !important;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.2);
            text-decoration: none;
        }

        .btn-discord:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(0, 0, 0, 0.3);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
            background: var(--card-bg);
            padding: 8px 20px;
            border-radius: 40px;
            border: 1px solid var(--border-color);
            backdrop-filter: blur(10px);
            text-decoration: none;
            color: var(--text-color);
            transition: all 0.3s;
        }

        .user-info:hover {
            background: var(--primary-soft);
            transform: translateY(-2px);
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary);
        }

        .logout-btn {
            color: #ff4757;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 40px;
            transition: all 0.3s;
        }

        .logout-btn:hover {
            background: rgba(255, 71, 87, 0.1);
        }

        /* ===== КОНТЕЙНЕР ===== */
        .container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            position: relative;
            z-index: 2;
        }

        /* ===== ПРОФИЛЬ ===== */
        .profile-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            overflow: hidden;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-lg);
            transition: transform 0.3s;
        }

        .profile-card:hover {
            transform: translateY(-5px);
        }

        .profile-header {
            background: var(--gradient-2);
            padding: 50px 40px;
            text-align: center;
            position: relative;
        }

        .profile-avatar {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            border: 4px solid white;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            margin-bottom: 20px;
            transition: transform 0.3s;
        }

        .profile-avatar:hover {
            transform: scale(1.05);
        }

        .profile-header h1 {
            font-size: 2.2rem;
            color: white;
            margin-bottom: 5px;
        }

        .profile-header .discord-tag {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.9rem;
        }

        .profile-rank {
            display: inline-block;
            background: rgba(0, 0, 0, 0.3);
            padding: 5px 20px;
            border-radius: 30px;
            font-size: 0.9rem;
            margin-top: 10px;
            backdrop-filter: blur(5px);
        }

        /* ===== СТАТИСТИКА ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            padding: 30px;
            background: var(--card-bg-solid);
            border-bottom: 1px solid var(--border-color);
        }

        .stat-card {
            text-align: center;
            padding: 20px;
            background: var(--primary-soft);
            border-radius: 25px;
            transition: all 0.3s;
            border: 1px solid var(--border-color);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            background: rgba(0, 0, 0, 0.08);
            border-color: var(--primary);
        }

        [data-theme="dark"] .stat-card:hover {
            background: rgba(183, 148, 244, 0.2);
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--text-color);
            opacity: 0.7;
            margin-top: 5px;
        }

        /* ===== КОНТЕНТ ===== */
        .profile-content {
            padding: 30px;
        }

        .section {
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 1.6rem;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--primary);
            display: inline-block;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            background: var(--primary-soft);
            border-radius: 25px;
            padding: 20px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .info-item:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 600;
            opacity: 0.7;
        }

        .info-value {
            font-weight: 500;
            color: var(--primary);
        }

        /* ===== СТРУКТУРА (УЛУЧШЕННАЯ) ===== */
        .structure-card {
            background: linear-gradient(135deg, var(--primary-soft), var(--card-bg));
            border-radius: 25px;
            padding: 25px;
            margin-top: 20px;
            border: 1px solid var(--border-color);
            transition: all 0.3s;
        }

        .structure-card:hover {
            transform: translateX(10px);
            border-color: var(--primary);
        }

        .structure-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .structure-icon {
            font-size: 2.5rem;
        }

        .structure-name {
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--primary);
        }

        .structure-rank {
            background: var(--gradient-2);
            padding: 5px 15px;
            border-radius: 30px;
            font-size: 0.85rem;
            color: white;
        }

        .structure-details {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 20px 0;
            padding: 15px;
            background: rgba(0, 0, 0, 0.03);
            border-radius: 20px;
        }

        [data-theme="dark"] .structure-details {
            background: rgba(255, 255, 255, 0.05);
        }

        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .detail-label {
            font-size: 0.8rem;
            opacity: 0.6;
        }

        .detail-value {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--primary);
        }

        .structure-stats {
            display: flex;
            gap: 25px;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--border-color);
            flex-wrap: wrap;
        }

        .structure-stat {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .structure-stat span:first-child {
            font-size: 1.2rem;
        }

        /* ===== ИМУЩЕСТВО ===== */
        .property-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .property-card {
            background: var(--primary-soft);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s;
            border: 1px solid var(--border-color);
        }

        .property-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
            box-shadow: var(--shadow-md);
        }

        .property-icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .property-id {
            font-size: 0.8rem;
            color: var(--primary);
            margin-bottom: 5px;
            font-weight: 600;
        }

        .property-type {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .property-price {
            font-size: 0.9rem;
            color: var(--text-color);
            opacity: 0.8;
        }

        .property-license {
            font-size: 0.75rem;
            margin-top: 8px;
            padding-top: 5px;
            border-top: 1px solid var(--border-color);
            color: var(--warning);
        }

        /* ===== ДОСТИЖЕНИЯ ===== */
        .achievements-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
        }

        .achievement-card {
            background: var(--primary-soft);
            border-radius: 20px;
            padding: 15px;
            text-align: center;
            transition: all 0.3s;
            border: 1px solid var(--border-color);
        }

        .achievement-card:hover {
            transform: translateY(-3px);
            border-color: var(--primary);
        }

        .achievement-icon {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        .achievement-name {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 5px;
        }

        .achievement-desc {
            font-size: 0.75rem;
            opacity: 0.6;
        }

        /* ===== ОШИБКА ===== */
        .error-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 40px;
            padding: 60px;
            text-align: center;
            backdrop-filter: blur(10px);
        }

        .error-icon {
            font-size: 5rem;
            margin-bottom: 20px;
        }

        .error-message {
            color: #ff4757;
            margin-bottom: 20px;
            font-size: 1.2rem;
        }

        .btn {
            display: inline-block;
            padding: 12px 35px;
            background: var(--gradient-2);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            transition: all 0.3s;
            font-weight: 600;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        /* ===== ФУТЕР ===== */
        .footer {
            text-align: center;
            padding: 40px 0;
            background: var(--header-bg);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--border-color);
            color: var(--footer-color);
            font-size: 0.9rem;
            position: relative;
            z-index: 2;
            margin-top: 40px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--footer-color);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: var(--primary);
        }

        /* ===== КНОПКА "НАВЕРХ" ===== */
        .scroll-top {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 60px;
            height: 60px;
            background: var(--gradient-2);
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 1.8rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.4s;
            z-index: 99;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .scroll-top.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .scroll-top:hover {
            transform: scale(1.15) rotate(360deg);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        /* ===== АДАПТИВНОСТЬ ===== */
        @media (max-width: 900px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .info-grid, .structure-details {
                grid-template-columns: 1fr;
            }
            .header {
                flex-direction: column;
                gap: 20px;
            }
            .nav-center {
                order: 2;
                width: 100%;
            }
            .logo {
                order: 1;
            }
            .header-right {
                order: 3;
            }
            .profile-header h1 {
                font-size: 1.8rem;
            }
            .profile-avatar {
                width: 100px;
                height: 100px;
            }
        }

        @media (max-width: 600px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .property-list, .achievements-grid {
                grid-template-columns: 1fr;
            }
            .structure-stats {
                flex-direction: column;
                gap: 10px;
            }
            .profile-header {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <div class="animated-bg"></div>
    <div class="minecraft-characters">
        <div class="character character-1"><img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%236b46c1'/%3E%3Ccircle cx='30' cy='35' r='8' fill='white'/%3E%3Ccircle cx='70' cy='35' r='8' fill='white'/%3E%3Crect x='40' y='60' width='20' height='15' fill='%23f687b3'/%3E%3C/svg%3E" alt="Minecraft Character"></div>
        <div class="character character-2"><img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%239f7aea'/%3E%3Ccircle cx='30' cy='35' r='8' fill='white'/%3E%3Ccircle cx='70' cy='35' r='8' fill='white'/%3E%3Crect x='40' y='60' width='20' height='15' fill='%23fbbf6e'/%3E%3C/svg%3E" alt="Minecraft Character"></div>
        <div class="character character-3"><img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%2338a169'/%3E%3Ccircle cx='30' cy='35' r='8' fill='white'/%3E%3Ccircle cx='70' cy='35' r='8' fill='white'/%3E%3Crect x='40' y='60' width='20' height='15' fill='%239ae6b4'/%3E%3C/svg%3E" alt="Minecraft Character"></div>
        <div class="character character-4"><img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23f687b3'/%3E%3Ccircle cx='30' cy='35' r='8' fill='white'/%3E%3Ccircle cx='70' cy='35' r='8' fill='white'/%3E%3Crect x='40' y='60' width='20' height='15' fill='%23fbbf6e'/%3E%3C/svg%3E" alt="Minecraft Character"></div>
        <div class="character character-5"><img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23b794f4'/%3E%3Ccircle cx='30' cy='35' r='8' fill='white'/%3E%3Ccircle cx='70' cy='35' r='8' fill='white'/%3E%3Crect x='40' y='60' width='20' height='15' fill='%2368d391'/%3E%3C/svg%3E" alt="Minecraft Character"></div>
    </div>
    <div class="floating-cubes">
        <div class="cube cube-1"></div>
        <div class="cube cube-2"></div>
        <div class="cube cube-3"></div>
        <div class="cube cube-4"></div>
    </div>

    <header class="header">
        <div class="logo">
            <img src="/images/logo.jpg" alt="Resistance">
            <h2>Resistance</h2>
        </div>
        
        <nav class="nav-center">
            <a href="/">Главная</a>
            <a href="/top">Топ</a>
            <a href="/career">Карьера</a>
        
            <a href="/profile" class="active">Профиль</a>
            <% if (user && user.isAdmin) { %>
                <a href="/admin/dashboard">Админ-панель</a>
            <% } else { %>
                <a href="/admin/login">Админ-панель</a>
            <% } %>
        </nav>
        
        <div class="header-right">
            <button id="theme-toggle" class="theme-toggle" aria-label="Переключить тему">
                <svg class="sun" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/></svg>
                <svg class="moon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
            <% if (user) { %>
                <a href="/profile" class="user-info">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=40" class="user-avatar" onerror="this.src='/images/player.jpg'">
                    <span><%= user.username %></span>
                </a>
                <a href="/auth/logout" class="logout-btn">Выйти</a>
            <% } else { %>
                <a href="/auth/discord" class="btn-discord">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.09.09 0 0 0-.07.03c-.18.33-.39.76-.53 1.09a16.09 16.09 0 0 0-4.8 0c-.14-.33-.35-.76-.54-1.09c-.01-.02-.04-.03-.07-.03c-1.5.26-2.93.71-4.27 1.33c-.01 0-.02.01-.03.02c-2.72 4.07-3.47 8.03-3.1 11.95c0 .02.01.04.03.05c1.8 1.32 3.53 2.12 5.24 2.65c.03.01.06 0 .07-.02c.4-.55.76-1.13 1.07-1.74c.02-.04 0-.08-.04-.09c-.57-.22-1.11-.48-1.64-.78c-.04-.02-.04-.08-.01-.11c.11-.08.22-.17.33-.25c.02-.02.05-.02.07-.01c3.44 1.57 7.15 1.57 10.55 0c.02-.01.05-.01.07.01c.11.09.22.17.33.26c.03.02.03.08-.01.11c-.52.31-1.07.56-1.64.78c-.04.01-.05.06-.04.09c.32.61.68 1.19 1.07 1.74c.03.01.06.02.09.01c1.72-.53 3.45-1.33 5.25-2.65c.02-.01.03-.03.03-.05c.44-4.53-.73-8.46-3.1-11.95c-.01-.01-.02-.02-.04-.02zM8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.84 2.12-1.89 2.12zm6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.83 2.12-1.89 2.12z"/></svg>
                    Войти
                </a>
            <% } %>
        </div>
    </header>

    <div class="container">
        <% if (error) { %>
            <div class="error-card">
                <div class="error-icon">⚠️</div>
                <div class="error-message"><%= error %></div>
                <a href="/" class="btn">На главную</a>
            </div>
        <% } else if (player) { %>
            <div class="profile-card">
                <div class="profile-header">
                    <img src="https://mc-heads.net/avatar/<%= player.minecraft_nick %>/140" 
                         alt="<%= player.minecraft_nick %>" 
                         class="profile-avatar"
                         onerror="this.src='/images/player.jpg'">
                    <h1><%= player.minecraft_nick %></h1>
                    <div class="discord-tag"><%= user.username %></div>
                    <div class="profile-rank">🎖️ <%= player.rank %></div>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value"><%= kills %></div>
                        <div class="stat-label">Убийств</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value"><%= deaths %></div>
                        <div class="stat-label">Смертей</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value"><%= kd %></div>
                        <div class="stat-label">K/D</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value"><%= player.total_hours || 0 %></div>
                        <div class="stat-label">Часов в клане</div>
                    </div>
                </div>

                <div class="profile-content">
                    <!-- Основная информация -->
                    <div class="section">
                        <h2 class="section-title">📋 Основная информация</h2>
                        <div class="info-grid">
                            <div class="info-item">
                                <span class="info-label">ID игрока</span>
                                <span class="info-value">#<%= player.id %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">В клане с</span>
                                <span class="info-value"><%= new Date(player.joined_at).toLocaleDateString('ru-RU') %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Пригласил</span>
                                <span class="info-value"><%= player.invited_by || 'Система' %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Последний раз</span>
                                <span class="info-value"><%= player.last_seen ? new Date(player.last_seen).toLocaleDateString('ru-RU') : 'Недавно' %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Статус</span>
                                <span class="info-value"><%= player.is_online ? '🟢 Онлайн' : '⚪ Оффлайн' %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Discord</span>
                                <span class="info-value"><%= player.discord_id ? '✅ Привязан' : '❌ Не привязан' %></span>
                            </div>
                        </div>
                    </div>

                    <!-- RolePlay информация -->
                    <% if (rpPlayer) { %>
                    <div class="section">
                        <h2 class="section-title">🎭 RolePlay</h2>
                        <div class="info-grid">
                            <div class="info-item">
                                <span class="info-label">Баланс</span>
                                <span class="info-value"><%= rpPlayer.money.toLocaleString('ru-RU') %> ₽</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">В RP с</span>
                                <span class="info-value"><%= new Date(rpPlayer.rp_joined).toLocaleDateString('ru-RU') %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Баллы активности</span>
                                <span class="info-value"><%= rpPlayer.unique_points || 0 %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">PayDay получено</span>
                                <span class="info-value"><%= rpPlayer.paydays_attended || 0 %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Образование</span>
                                <span class="info-value"><%= rpPlayer.education ? '✅ Получено' : '❌ Не получено' %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Специальное образование</span>
                                <span class="info-value"><%= rpPlayer.special_education && rpPlayer.special_education !== 'none' ? '✅ ' + rpPlayer.special_education : '❌ Не получено' %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Выговоров</span>
                                <span class="info-value"><%= rpPlayer.warns || 0 %>/3</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Статус</span>
                                <span class="info-value"><%= rpPlayer.frozen ? '❄️ Заморожен' : '✅ Активен' %></span>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <!-- СТРУКТУРА (УЛУЧШЕННАЯ) -->
                    <% if (structureInfo) { %>
                    <div class="section">
                        <h2 class="section-title">🏛️ Служба в структуре</h2>
                        <div class="structure-card">
                            <div class="structure-header">
                                <span class="structure-icon">
                                    <% if (structureInfo.name === 'Полиция') { %>🚔
                                    <% } else if (structureInfo.name === 'Армия') { %>⚔️
                                    <% } else if (structureInfo.name === 'Больница') { %>🏥
                                    <% } else if (structureInfo.name === 'Академия') { %>📚
                                    <% } else if (structureInfo.name === 'Мэрия') { %>🏛️
                                    <% } else if (structureInfo.name === 'Суд') { %>⚖️
                                    <% } else { %>📌<% } %>
                                </span>
                                <span class="structure-name"><%= structureInfo.name %></span>
                                <span class="structure-rank"><%= structureInfo.rank || 'Участник' %></span>
                            </div>
                            
                            <div class="structure-details">
                                <div class="detail-item">
                                    <span class="detail-label">Дата назначения</span>
                                    <span class="detail-value"><%= structureInfo.joined_at ? new Date(structureInfo.joined_at).toLocaleDateString('ru-RU') : 'Неизвестно' %></span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Стаж в структуре</span>
                                    <span class="detail-value"><%= structureInfo.stazh || '0' %> дней</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Выговоров в структуре</span>
                                    <span class="detail-value"><%= structureInfo.warns || 0 %>/3</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">На дежурстве</span>
                                    <span class="detail-value"><%= structureInfo.on_duty ? '🟢 Да' : '⚪ Нет' %></span>
                                </div>
                            </div>
                            
                            <div class="structure-stats">
                                <div class="structure-stat">
                                    <span>👥</span>
                                    <span>Сотрудников: <strong><%= structureInfo.members || 0 %></strong></span>
                                </div>
                                <div class="structure-stat">
                                    <span>💰</span>
                                    <span>Бюджет: <strong><%= structureInfo.budget?.toLocaleString('ru-RU') || 0 %> ₽</strong></span>
                                </div>
                                <div class="structure-stat">
                                    <span>⭐</span>
                                    <span>Ваш рейтинг: <strong><%= structureInfo.rating || 'Средний' %></strong></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <!-- ДОСТИЖЕНИЯ (динамически генерируются из данных игрока) -->
                    <div class="section">
                        <h2 class="section-title">🏆 Достижения</h2>
                        <div class="achievements-grid">
                            <% if (rpPlayer && rpPlayer.money >= 100000) { %>
                            <div class="achievement-card"><div class="achievement-icon">💰</div><div class="achievement-name">Миллионер</div><div class="achievement-desc">Накоплено 100 000 ₽</div></div>
                            <% } %>
                            <% if (rpPlayer && rpPlayer.money >= 500000) { %>
                            <div class="achievement-card"><div class="achievement-icon">💎</div><div class="achievement-name">Магнат</div><div class="achievement-desc">Накоплено 500 000 ₽</div></div>
                            <% } %>
                            <% if (rpPlayer && rpPlayer.paydays_attended >= 10) { %>
                            <div class="achievement-card"><div class="achievement-icon">💵</div><div class="achievement-name">Трудяга</div><div class="achievement-desc">Получено 10 PayDay</div></div>
                            <% } %>
                            <% if (rpPlayer && rpPlayer.paydays_attended >= 50) { %>
                            <div class="achievement-card"><div class="achievement-icon">🏅</div><div class="achievement-name">Ветеран труда</div><div class="achievement-desc">Получено 50 PayDay</div></div>
                            <% } %>
                            <% if (rpPlayer && rpPlayer.education) { %>
                            <div class="achievement-card"><div class="achievement-icon">📖</div><div class="achievement-name">Образованный</div><div class="achievement-desc">Получено среднее образование</div></div>
                            <% } %>
                            <% if (rpPlayer && rpPlayer.special_education && rpPlayer.special_education !== 'none') { %>
                            <div class="achievement-card"><div class="achievement-icon">🎓</div><div class="achievement-name">Специалист</div><div class="achievement-desc">Получено специальное образование: <%= rpPlayer.special_education %></div></div>
                            <% } %>
                            <% if (kills >= 100) { %>
                            <div class="achievement-card"><div class="achievement-icon">⚔️</div><div class="achievement-name">Воин</div><div class="achievement-desc">100+ убийств</div></div>
                            <% } %>
                            <% if (kills >= 500) { %>
                            <div class="achievement-card"><div class="achievement-icon">👑</div><div class="achievement-name">Легенда PvP</div><div class="achievement-desc">500+ убийств</div></div>
                            <% } %>
                            <% if (player.total_hours >= 100) { %>
                            <div class="achievement-card"><div class="achievement-icon">⏳</div><div class="achievement-name">Ветеран</div><div class="achievement-desc">100+ часов в клане</div></div>
                            <% } %>
                            <% if (player.total_hours >= 500) { %>
                            <div class="achievement-card"><div class="achievement-icon">🌟</div><div class="achievement-name">Легенда клана</div><div class="achievement-desc">500+ часов в клане</div></div>
                            <% } %>
                            <% if (propertyList && propertyList.length >= 3) { %>
                            <div class="achievement-card"><div class="achievement-icon">🏘️</div><div class="achievement-name">Владелец недвижимости</div><div class="achievement-desc">Владелец 3+ объектов</div></div>
                            <% } %>
                            <% if (propertyList && propertyList.length >= 5) { %>
                            <div class="achievement-card"><div class="achievement-icon">🏰</div><div class="achievement-name">Магнат недвижимости</div><div class="achievement-desc">Владелец 5+ объектов</div></div>
                            <% } %>
                            <% if (structureInfo && structureInfo.rank === 'Мэр') { %>
                            <div class="achievement-card"><div class="achievement-icon">👑</div><div class="achievement-name">Мэр города</div><div class="achievement-desc">Глава города Resistance</div></div>
                            <% } %>
                            <% if (structureInfo && structureInfo.rank === 'Министр') { %>
                            <div class="achievement-card"><div class="achievement-icon">📋</div><div class="achievement-name">Министр</div><div class="achievement-desc">Член правительства</div></div>
                            <% } %>
                            <% if (structureInfo && (structureInfo.rank === 'Полковник' || structureInfo.rank === 'Маршал')) { %>
                            <div class="achievement-card"><div class="achievement-icon">⭐</div><div class="achievement-name">Высший офицер</div><div class="achievement-desc">Высокое звание в структуре</div></div>
                            <% } %>
                            <% if (!rpPlayer && !structureInfo && kills === 0 && deaths === 0) { %>
                            <div class="achievement-card"><div class="achievement-icon">🌱</div><div class="achievement-name">Новичок</div><div class="achievement-desc">Добро пожаловать в Resistance!</div></div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Имущество -->
                    <% if (propertyList && propertyList.length > 0) { %>
                    <div class="section">
                        <h2 class="section-title">🏠 Имущество</h2>
                        <div class="property-list">
                            <% propertyList.forEach(prop => { %>
                                <div class="property-card">
                                    <div class="property-icon">
                                        <% if (prop.type === 'apartment') { %>🏠
                                        <% } else if (prop.type === 'house') { %>🏡
                                        <% } else if (prop.type === 'business') { %>🏪
                                        <% } else if (prop.type === 'office') { %>🏢
                                        <% } else { %>📦<% } %>
                                    </div>
                                    <div class="property-id">ID: <%= prop.id %></div>
                                    <div class="property-type">
                                        <% if (prop.type === 'apartment') { %>Квартира
                                        <% } else if (prop.type === 'house') { %>Дом
                                        <% } else if (prop.type === 'business') { %>Бизнес
                                        <% } else if (prop.type === 'office') { %>Офис
                                        <% } else { %><%= prop.type %><% } %>
                                    </div>
                                    <div class="property-price"><%= prop.price.toLocaleString('ru-RU') %> ₽</div>
                                    <% if (prop.license_expires) { %>
                                    <div class="property-license">📜 Лицензия до: <%= new Date(prop.license_expires).toLocaleDateString('ru-RU') %></div>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
        <% } else { %>
            <div class="error-card">
                <div class="error-icon">🔗</div>
                <div class="error-message">Ваш Discord не привязан к Minecraft аккаунту</div>
                <a href="/" class="btn">На главную</a>
            </div>
        <% } %>
    </div>

    <footer class="footer">
        <div class="footer-links">
            <a href="/">Главная</a>
            <a href="/top">Топ</a>
            <a href="/career">Карьера</a>
            <a href="/profile">Профиль</a>
            <a href="/admin/login">Админ-панель</a>
        </div>
        <p>Resistance City Project • 2026 • Все права защищены</p>
        <p style="margin-top: 10px; font-size: 0.9rem;">Сделано с ❤️ для настоящих фанатов Minecraft</p>
    </footer>

    <button class="scroll-top" id="scrollTop" title="Наверх">↑</button>

    <script>
        (function() {
            const themeToggle = document.getElementById('theme-toggle');
            if (!themeToggle) return;
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'light') document.documentElement.setAttribute('data-theme', 'light');
            else if (savedTheme === 'dark' || (!savedTheme && prefersDark)) document.documentElement.setAttribute('data-theme', 'dark');
            else document.documentElement.setAttribute('data-theme', 'light');
            themeToggle.addEventListener('click', () => {
                const current = document.documentElement.getAttribute('data-theme');
                const newTheme = current === 'light' ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                themeToggle.style.transform = 'scale(1.2)';
                setTimeout(() => { themeToggle.style.transform = 'scale(1)'; }, 200);
            });
        })();

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
        }, { threshold: 0.2 });
        document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

        const scrollBtn = document.getElementById('scrollTop');
        window.addEventListener('scroll', () => { if (window.scrollY > 400) scrollBtn.classList.add('visible'); else scrollBtn.classList.remove('visible'); });
        scrollBtn.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); });
    </script>
</body>
</html>