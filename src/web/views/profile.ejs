<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Профиль игрока <%= typeof username !== 'undefined' ? username : 'Неизвестный' %> в Resistance City">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'Профиль игрока' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .profile-header-section {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 32px;
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
        }
        .profile-header-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--primary-lighter), var(--warning), var(--danger), var(--primary));
            background-size: 200% 100%;
            animation: gradientShift 3s ease infinite;
        }
        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .profile-avatar-large {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-lighter));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 800;
            color: white;
            flex-shrink: 0;
            box-shadow: 0 4px 16px rgba(99, 67, 212, 0.4);
        }
        .profile-mini-stat {
            text-align: center;
            padding: 12px 8px;
            background: rgba(255,255,255,0.02);
            border-radius: 10px;
        }
        .detail-table {
            width: 100%;
            border-collapse: collapse;
        }
        .detail-table td {
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .detail-table td:first-child {
            color: var(--text-secondary);
            width: 40%;
        }
        .detail-table td:last-child {
            font-weight: 600;
            text-align: right;
        }
        .timeline-entry {
            position: relative;
            padding-left: 24px;
            padding-bottom: 16px;
            border-left: 2px solid var(--border);
        }
        .timeline-entry::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 4px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--primary);
            border: 2px solid var(--border);
        }
        .timeline-entry:last-child {
            border-left-color: transparent;
        }
        .status-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }
        .status-indicator.active { background: var(--success); }
        .status-indicator.inactive { background: var(--danger); }
        .status-indicator.warning { background: var(--warning); }
    </style>
</head>
<body>
    <%- include('partials/header', { page: 'profile' }) %>

    <div class="container" style="margin-top: 32px;">

        <!-- ==================== ШАПКА ПРОФИЛЯ ==================== -->
        <div class="profile-header-section animate-on-scroll">
            <div style="display: flex; align-items: center; gap: 24px; flex-wrap: wrap;">
                <div class="profile-avatar-large">
                    <%= typeof username !== 'undefined' && username ? username.charAt(0).toUpperCase() : '?' %>
                </div>
                <div style="flex: 1; min-width: 250px;">
                    <h1 style="margin-bottom: 4px; font-size: 2rem;">
                        <%= typeof username !== 'undefined' ? username : 'Неизвестный игрок' %>
                    </h1>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px;">
                        <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_active) { %>
                            <span class="badge badge-success"><span class="status-indicator active"></span> RP Активен</span>
                        <% } else { %>
                            <span class="badge badge-danger"><span class="status-indicator inactive"></span> RP Неактивен</span>
                        <% } %>
                        
                        <% if (typeof clanMember !== 'undefined' && clanMember && clanMember.is_in_clan) { %>
                            <span class="badge badge-primary">⚔ В клане</span>
                        <% } else { %>
                            <span class="badge badge-warning">🚫 Не в клане</span>
                        <% } %>
                        
                        <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.organization) { %>
                            <span class="badge badge-info">🏛️ <%= rpMember.organization %></span>
                        <% } %>
                        
                        <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_in_jail) { %>
                            <span class="badge badge-danger">🔒 В тюрьме</span>
                        <% } %>
                        
                        <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_sick) { %>
                            <span class="badge badge-warning"><span class="status-indicator warning"></span> Болен</span>
                        <% } %>
                        
                        <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_frozen) { %>
                            <span class="badge badge-info">❄️ Заморожен</span>
                        <% } %>
                    </div>
                    
                    <% if (typeof rpMember !== 'undefined' && rpMember) { %>
                        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">
                            ID: <strong style="color: var(--text-bright);"><%= rpMember.id %></strong> • 
                            В RP с <strong style="color: var(--text-bright);">
                                <%= rpMember.rp_joined_at ? new Date(rpMember.rp_joined_at).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }) : 'неизвестно' %>
                            </strong>
                        </p>
                    <% } %>
                    
                    <% if (typeof clanMember !== 'undefined' && clanMember && clanMember.is_in_clan) { %>
                        <p style="color: var(--text-muted); font-size: 0.9rem; margin: 4px 0 0 0;">
                            В клане с <strong style="color: var(--text-bright);">
                                <%= clanMember.joined_at ? new Date(clanMember.joined_at).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }) : 'неизвестно' %>
                            </strong>
                            <% if (clanMember.added_by) { %>
                                • Пригласил: <strong style="color: var(--info);"><%= clanMember.added_by %></strong>
                            <% } %>
                        </p>
                    <% } %>
                </div>
            </div>

            <!-- МИНИ-СТАТИСТИКА В ШАПКЕ -->
            <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_active) { %>
                <div class="grid grid-4" style="margin-top: 24px; gap: 12px;">
                    <div class="profile-mini-stat">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--success);">
                            <%= (rpMember.balance || 0).toLocaleString() %> ₽
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Баланс</div>
                    </div>
                    <div class="profile-mini-stat">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary-lighter);">
                            <%= rpMember.points || 0 %>
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Баллов</div>
                    </div>
                    <div class="profile-mini-stat">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--info);">
                            <%= (rpMember.total_hours || 0).toFixed(1) %> ч
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">В RP</div>
                    </div>
                    <div class="profile-mini-stat">
                        <div style="font-size: 1.5rem; font-weight: 700; color: var(--warning);">
                            <%= rpMember.payday_count || 0 %>
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">PayDay'ев</div>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <div class="grid grid-2">
            
            <!-- ==================== ЛЕВАЯ КОЛОНКА ==================== -->
            <div>
                
                <!-- RP ПРОФИЛЬ -->
                <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_active) { %>
                    <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                        <div class="card-header">
                            <h3 class="card-title">👤 RolePlay профиль</h3>
                        </div>
                        <div class="card-body">
                            <table class="detail-table">
                                <tbody>
                                    <tr>
                                        <td>Баланс</td>
                                        <td style="font-weight: 700; color: var(--success); font-size: 1.1rem;">
                                            <%= (rpMember.balance || 0).toLocaleString() %> ₽
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Банковский счёт</td>
                                        <td style="font-weight: 700; color: var(--info);">
                                            <%= typeof bankAccount !== 'undefined' && bankAccount ? (bankAccount.balance || 0).toLocaleString() : '0' %> ₽
                                        </td>
                                    </tr>
                                    <% if (typeof bankAccount !== 'undefined' && bankAccount && bankAccount.deposit_amount > 0) { %>
                                        <tr>
                                            <td>Депозит</td>
                                            <td style="font-weight: 600; color: var(--success);">
                                                <%= bankAccount.deposit_amount.toLocaleString() %> ₽ 
                                                (под <%= (bankAccount.deposit_rate * 100).toFixed(1) %>%)
                                            </td>
                                        </tr>
                                    <% } %>
                                    <% if (typeof bankAccount !== 'undefined' && bankAccount && bankAccount.credit_amount > 0) { %>
                                        <tr>
                                            <td>Кредит</td>
                                            <td style="font-weight: 600; color: var(--danger);">
                                                <%= bankAccount.credit_amount.toLocaleString() %> ₽
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>Погасить до</td>
                                            <td style="font-weight: 600; color: var(--warning);">
                                                <%= bankAccount.credit_due_date ? new Date(bankAccount.credit_due_date).toLocaleDateString('ru-RU') : '—' %>
                                            </td>
                                        </tr>
                                    <% } %>
                                    <tr>
                                        <td>Всего средств</td>
                                        <td style="font-weight: 700; color: var(--primary-lighter); font-size: 1.1rem;">
                                            <% 
                                                var totalFunds = (rpMember.balance || 0);
                                                if (typeof bankAccount !== 'undefined' && bankAccount) {
                                                    totalFunds += (bankAccount.balance || 0);
                                                }
                                            %>
                                            <%= totalFunds.toLocaleString() %> ₽
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
                                <table class="detail-table">
                                    <tbody>
                                        <tr>
                                            <td>Организация</td>
                                            <td>
                                                <% if (rpMember.organization) { %>
                                                    <span class="badge badge-info"><%= rpMember.organization %></span>
                                                <% } else { %>
                                                    <span style="color: var(--text-muted);">Безработный</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% if (rpMember.rank) { %>
                                            <tr>
                                                <td>Должность</td>
                                                <td style="color: var(--text-bright);"><%= rpMember.rank %></td>
                                            </tr>
                                        <% } %>
                                        <tr>
                                            <td>Баллы активности</td>
                                            <td style="color: var(--primary-lighter);"><%= rpMember.points || 0 %></td>
                                        </tr>
                                        <tr>
                                            <td>Часов в RP</td>
                                            <td><%= (rpMember.total_hours || 0).toFixed(1) %> ч</td>
                                        </tr>
                                        <tr>
                                            <td>Получено PayDay'ев</td>
                                            <td style="color: var(--warning);"><%= rpMember.payday_count || 0 %></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="card animate-on-scroll" style="margin-bottom: 24px; text-align: center;">
                        <div style="font-size: 3rem; margin-bottom: 12px;">📋</div>
                        <h3>Не в RolePlay</h3>
                        <p style="color: var(--text-secondary); padding: 0 20px;">
                            Игрок не зарегистрирован в системе RolePlay Resistance.
                        </p>
                        <p style="color: var(--text-muted); font-size: 0.85rem;">
                            Для регистрации используйте команду <code style="color: var(--info);">/rp</code> в игре.
                        </p>
                    </div>
                <% } %>

                <!-- СТАТУС -->
                <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_active) { %>
                    <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                        <div class="card-header">
                            <h3 class="card-title">📍 Текущий статус</h3>
                        </div>
                        <div class="card-body">
                            <table class="detail-table">
                                <tbody>
                                    <tr>
                                        <td>В городе</td>
                                        <td>
                                            <% if (rpMember.is_in_city) { %>
                                                <span class="badge badge-success">Да</span>
                                            <% } else { %>
                                                <span class="badge badge-warning">Нет (покинул город)</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Тюрьма</td>
                                        <td>
                                            <% if (rpMember.is_in_jail) { %>
                                                <span class="badge badge-danger">Заключён</span>
                                            <% } else { %>
                                                <span class="badge badge-success">Свободен</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% if (rpMember.is_in_jail && rpMember.jail_until) { %>
                                        <tr>
                                            <td>Освобождение</td>
                                            <td style="color: var(--warning); font-size: 0.9rem;">
                                                <%= new Date(rpMember.jail_until).toLocaleDateString('ru-RU') %>
                                                <br><small style="color: var(--text-muted);">
                                                    осталось: <%= getTimeRemaining(rpMember.jail_until) %>
                                                </small>
                                            </td>
                                        </tr>
                                    <% } %>
                                    <tr>
                                        <td>Здоровье</td>
                                        <td>
                                            <% if (rpMember.is_sick) { %>
                                                <span class="badge badge-warning">Болен</span>
                                            <% } else { %>
                                                <span class="badge badge-success">Здоров</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% if (rpMember.is_sick && rpMember.sick_until) { %>
                                        <tr>
                                            <td>Выздоровление</td>
                                            <td style="color: var(--info); font-size: 0.9rem;">
                                                <%= new Date(rpMember.sick_until).toLocaleDateString('ru-RU') %>
                                                <br><small style="color: var(--text-muted);">
                                                    осталось: <%= getTimeRemaining(rpMember.sick_until) %>
                                                </small>
                                            </td>
                                        </tr>
                                    <% } %>
                                    <tr>
                                        <td>Заморозка</td>
                                        <td>
                                            <% if (rpMember.is_frozen) { %>
                                                <span class="badge badge-danger">Да</span>
                                            <% } else { %>
                                                <span class="badge badge-success">Нет</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <% if (rpMember.is_frozen && rpMember.frozen_reason) { %>
                                        <tr>
                                            <td>Причина заморозки</td>
                                            <td style="color: var(--danger); font-size: 0.9rem;"><%= rpMember.frozen_reason %></td>
                                        </tr>
                                    <% } %>
                                    <tr>
                                        <td>Предупреждений</td>
                                        <td>
                                            <% if (rpMember.warns > 0) { %>
                                                <span class="badge badge-danger"><%= rpMember.warns %>/3</span>
                                            <% } else { %>
                                                <span class="badge badge-success">0</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>ЧС в RP</td>
                                        <td>
                                            <% if (rpMember.blacklisted_from_rp) { %>
                                                <span class="badge badge-danger">Да</span>
                                            <% } else { %>
                                                <span class="badge badge-success">Нет</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- ==================== ПРАВАЯ КОЛОНКА ==================== -->
            <div>
                
                <!-- КЛАН -->
                <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                    <div class="card-header">
                        <h3 class="card-title">⚔️ Клан Resistance</h3>
                    </div>
                    <div class="card-body">
                        <% if (typeof clanMember !== 'undefined' && clanMember && clanMember.is_in_clan) { %>
                            <table class="detail-table">
                                <tbody>
                                    <tr>
                                        <td>Ранг в клане</td>
                                        <td style="color: var(--primary-lighter);"><%= clanMember.rank || 'Участник' %></td>
                                    </tr>
                                    <tr>
                                        <td>Убийств</td>
                                        <td style="font-weight: 700; color: var(--danger); font-size: 1.1rem;"><%= clanMember.kills || 0 %></td>
                                    </tr>
                                    <tr>
                                        <td>Смертей</td>
                                        <td style="font-weight: 700; color: var(--warning);"><%= clanMember.deaths || 0 %></td>
                                    </tr>
                                    <tr>
                                        <td>K/D</td>
                                        <td style="font-weight: 700; color: var(--info); font-size: 1.1rem;">
                                            <%= clanMember.deaths > 0 ? (clanMember.kills / clanMember.deaths).toFixed(2) : (clanMember.kills || '0') %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Часов в клане</td>
                                        <td><%= (clanMember.hours_in_clan || 0).toFixed(1) %> ч</td>
                                    </tr>
                                    <tr>
                                        <td>Discord</td>
                                        <td>
                                            <% if (clanMember.discord_verified) { %>
                                                <span class="badge badge-success">✅ Привязан</span>
                                            <% } else { %>
                                                <span class="badge badge-warning">⚠ Не привязан</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        <% } else { %>
                            <div style="text-align: center; padding: 20px; color: var(--text-muted);">
                                <div style="font-size: 2rem; margin-bottom: 8px;">🚫</div>
                                <p>Игрок не состоит в клане Resistance</p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- ДОКУМЕНТЫ -->
                <% if (typeof rpMember !== 'undefined' && rpMember && rpMember.is_active) { %>
                    <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                        <div class="card-header">
                            <h3 class="card-title">📄 Документы и лицензии</h3>
                        </div>
                        <div class="card-body">
                            <table class="detail-table">
                                <tbody>
                                    <tr>
                                        <td>Образование</td>
                                        <td>
                                            <% if (typeof education !== 'undefined' && education && education.has_basic) { %>
                                                <span class="badge badge-success">✅ Базовое</span>
                                            <% } else { %>
                                                <span class="badge badge-danger">❌ Отсутствует</span>
                                            <% } %>
                                            <% if (typeof education !== 'undefined' && education && education.has_advanced) { %>
                                                <span class="badge badge-info" style="margin-left: 4px;">+ Дополнительное</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Медкнижка</td>
                                        <td>
                                            <% if (rpMember.medical_book) { %>
                                                <span class="badge badge-success">✅ Действительна</span>
                                                <% if (rpMember.medical_book_expires) { %>
                                                    <br><small style="color: var(--text-muted);">
                                                        до <%= new Date(rpMember.medical_book_expires).toLocaleDateString('ru-RU') %>
                                                    </small>
                                                <% } %>
                                            <% } else { %>
                                                <span class="badge badge-danger">❌ Отсутствует</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <% if (typeof education !== 'undefined' && education && education.has_basic && education.courses_passed) { %>
    <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border);">
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px;">
            📚 Пройденные курсы:
        </p>
        <% 
            var courses = education.courses_passed.split(',');
            var gradesList = (education.grades || '').split(',');
            for (var c = 0; c < Math.min(courses.length, 10); c++) {
                var gradeNum = parseInt(gradesList[c]) || 0;
                var gradeEmoji = gradeNum === 5 ? '⭐' : gradeNum === 4 ? '✅' : gradeNum === 3 ? '✔️' : '❌';
        %>
            <div style="display: flex; justify-content: space-between; padding: 6px 0; font-size: 0.9rem;">
                <span style="color: var(--text-secondary);"><%= courses[c] %></span>
                <% if (gradeNum === 5) { %>
                    <span style="font-weight: 600; color: #aa4eff;">
                        <%= gradeEmoji %> <%= gradesList[c] || '—' %>
                    </span>
                <% } else if (gradeNum === 4) { %>
                    <span style="font-weight: 600; color: #76C519;">
                        <%= gradeEmoji %> <%= gradesList[c] || '—' %>
                    </span>
                <% } else if (gradeNum === 3) { %>
                    <span style="font-weight: 600; color: #FFB800;">
                        <%= gradeEmoji %> <%= gradesList[c] || '—' %>
                    </span>
                <% } else if (gradeNum === 2) { %>
                    <span style="font-weight: 600; color: #CA4E4E;">
                        <%= gradeEmoji %> <%= gradesList[c] || '—' %>
                    </span>
                <% } else { %>
                    <span style="font-weight: 600; color: #D4D4D4;">
                        <%= gradeEmoji %> <%= gradesList[c] || '—' %>
                    </span>
                <% } %>
            </div>
        <% } %>
    </div>
<% } %>

                            <% if (typeof licenses !== 'undefined' && licenses && licenses.length > 0) { %>
                                <div style="margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border);">
                                    <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px;">
                                        📋 Активные лицензии:
                                    </p>
                                    <% for (var l = 0; l < licenses.length; l++) { 
                                        var lic = licenses[l];
                                        var licNames = {
                                            'business': 'Предпринимательская',
                                            'office': 'На офис',
                                            'medbook': 'Медкнижка',
                                            'education_advanced': 'Доп. образование'
                                        };
                                        var licName = licNames[lic.license_type] || lic.license_type;
                                    %>
                                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 6px 0; font-size: 0.9rem;">
                                            <span class="badge badge-info"><%= licName %></span>
                                            <span style="color: var(--text-muted); font-size: 0.8rem;">
                                                до <%= lic.expires_at ? new Date(lic.expires_at).toLocaleDateString('ru-RU') : '—' %>
                                            </span>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>

                <!-- ИМУЩЕСТВО -->
                <% if (typeof properties !== 'undefined' && properties && properties.length > 0) { %>
                    <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                        <div class="card-header">
                            <h3 class="card-title">🏠 Имущество (<%= properties.length %>)</h3>
                        </div>
                        <div class="card-body">
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                <% for (var p = 0; p < properties.length; p++) { 
                                    var prop = properties[p];
                                    var propTypeNames = {
                                        'apartment': 'Квартира',
                                        'house': 'Дом',
                                        'office': 'Офис',
                                        'business': 'Бизнес',
                                        'port': 'Порт'
                                    };
                                    var propTypeName = propTypeNames[prop.property_type] || prop.property_type;
                                    var isOwner = (prop.owner_lower || '').toLowerCase() === (typeof username !== 'undefined' ? username : '').toLowerCase();
                                %>
                                    <div style="padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.02); border-left: 3px solid var(--primary);">
                                        <div style="display: flex; justify-content: space-between; align-items: center;">
                                            <div>
                                                <strong style="color: var(--text-bright);">#<%= prop.property_id %></strong>
                                                <span style="color: var(--text-muted); margin-left: 8px;"><%= propTypeName %></span>
                                            </div>
                                            <span class="badge <%= isOwner ? 'badge-info' : 'badge-warning' %>" style="font-size: 0.7rem;">
                                                <%= isOwner ? 'Владелец' : 'Сожитель' %>
                                            </span>
                                        </div>
                                        <% if (prop.co_owner_1 || prop.co_owner_2) { %>
                                            <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px;">
                                                Сожители: 
                                                <% if (prop.co_owner_1) { %><%= prop.co_owner_1 %><% } %>
                                                <% if (prop.co_owner_1 && prop.co_owner_2) { %>, <% } %>
                                                <% if (prop.co_owner_2) { %><%= prop.co_owner_2 %><% } %>
                                            </div>
                                        <% } %>
                                        <% if (prop.region_name) { %>
                                            <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 2px;">
                                                Регион: <code style="color: var(--info);"><%= prop.region_name %></code>
                                            </div>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ==================== ФИНАНСОВАЯ АКТИВНОСТЬ ==================== -->
        <% if (typeof monthlyBalanceChanges !== 'undefined' && monthlyBalanceChanges && monthlyBalanceChanges.length > 0) { %>
            <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">📊 Финансовая активность (30 дней)</h3>
                </div>
                <div class="card-body">
                    <div style="display: flex; flex-wrap: wrap; gap: 12px;">
                        <% for (var bc = 0; bc < monthlyBalanceChanges.length; bc++) { 
                            var item = monthlyBalanceChanges[bc];
                            var typeNames = {
                                'payday': '💵 PayDay',
                                'transfer_sent': '📤 Переводы',
                                'transfer_received': '📥 Получено',
                                'property_buy': '🏠 Покупки',
                                'property_sell': '💰 Продажи',
                                'fine_payment': '📋 Штрафы',
                                'tax_payment': '🏛️ Налоги',
                                'admin_give': '⭐ Админ',
                                'bonus': '🎁 Премии',
                                'grant': '🎓 Гранты',
                            };
                            var typeName = typeNames[item.type] || item.type;
                        %>
                            <div style="flex: 1; min-width: 150px; padding: 12px; background: rgba(255,255,255,0.02); border-radius: 8px; text-align: center;">
                                <div style="font-size: 0.85rem; color: var(--text-muted);"><%= typeName %></div>
                                <div style="font-weight: 700; color: var(--info); font-size: 1.1rem;">
                                    <%= (item.total || 0).toLocaleString() %> ₽
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- ==================== НАКАЗАНИЯ ==================== -->
        <% if (typeof activePunishments !== 'undefined' && activePunishments && activePunishments.length > 0) { %>
            <div class="card animate-on-scroll" style="margin-bottom: 24px; border-color: var(--danger);">
                <div class="card-header">
                    <h3 class="card-title" style="color: var(--danger);">⚠ Активные наказания (<%= activePunishments.length %>)</h3>
                </div>
                <div class="card-body">
                    <% for (var ap = 0; ap < activePunishments.length; ap++) { 
                        var punishment = activePunishments[ap];
                        var typeNames = {
                            'mute': '🔇 Мут',
                            'pm_mute': '🔇 Мут ЛС',
                            'kick': '👢 Кик',
                            'blacklist': '🚫 ЧС',
                        };
                        var typeName = typeNames[punishment.type] || punishment.type;
                    %>
                        <div style="padding: 14px; border-radius: 8px; background: rgba(202,78,78,0.05); margin-bottom: 8px; border-left: 3px solid var(--danger);">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                                <span class="badge badge-danger"><%= typeName %></span>
                                <span style="color: var(--text-muted); font-size: 0.8rem;">
                                    Выдал: <strong><%= punishment.issued_by %></strong>
                                </span>
                            </div>
                            <p style="margin: 4px 0; font-size: 0.95rem; color: var(--text-secondary);"><%= punishment.reason %></p>
                            <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted);">
                                <span><%= punishment.issued_at ? new Date(punishment.issued_at).toLocaleDateString('ru-RU') : '—' %></span>
                                <% if (punishment.expires_at) { %>
                                    <span>До: <%= new Date(punishment.expires_at).toLocaleDateString('ru-RU') %> (<%= getTimeRemaining(punishment.expires_at) %>)</span>
                                <% } else { %>
                                    <span>Навсегда</span>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

        <!-- ==================== ШТРАФЫ ==================== -->
        <% if (typeof fines !== 'undefined' && fines && fines.length > 0) { %>
            <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">📋 Штрафы (<%= fines.length %>)</h3>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    <% for (var f = 0; f < Math.min(fines.length, 20); f++) { 
                        var fine = fines[f];
                        var statusNames = {
                            'pending': '⏳ Ожидает',
                            'paid': '✅ Оплачен',
                            'rejected': '❌ Отклонён',
                            'expired': '⌛ Просрочен',
                            'insufficient_funds': '💸 Нет средств',
                        };
                        var statusName = statusNames[fine.status] || fine.status;
                    %>
                        <div class="timeline-entry">
                            <div style="display: flex; justify-content: space-between;">
                                <span style="font-weight: 600; color: var(--text-bright);">
                                    <%= (fine.amount || 0).toLocaleString() %> ₽
                                </span>
                                <span class="badge <%= fine.status === 'paid' ? 'badge-success' : fine.status === 'pending' ? 'badge-warning' : 'badge-danger' %>">
                                    <%= statusName %>
                                </span>
                            </div>
                            <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 4px 0;"><%= fine.reason %></p>
                            <span style="font-size: 0.75rem; color: var(--text-muted);">
                                Выдал: <%= fine.issued_by %> • <%= fine.issued_at ? new Date(fine.issued_at).toLocaleDateString('ru-RU') : '—' %>
                            </span>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

        <!-- ==================== ТЮРЬМА ==================== -->
        <% if (typeof jailRecords !== 'undefined' && jailRecords && jailRecords.length > 0) { %>
            <div class="card animate-on-scroll" style="margin-bottom: 24px;">
                <div class="card-header">
                    <h3 class="card-title">🔒 История заключений (<%= jailRecords.length %>)</h3>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    <% for (var jr = 0; jr < Math.min(jailRecords.length, 20); jr++) { 
                        var record = jailRecords[jr];
                    %>
                        <div class="timeline-entry">
                            <div style="display: flex; justify-content: space-between;">
                                <span style="font-weight: 600; color: var(--danger);">
                                    <%= record.duration_minutes ? formatDuration(record.duration_minutes) : '—' %>
                                </span>
                                <span class="badge <%= record.is_active ? 'badge-danger' : 'badge-success' %>">
                                    <%= record.is_active ? '🔒 В тюрьме' : '✅ Освобождён' %>
                                </span>
                            </div>
                            <p style="font-size: 0.85rem; color: var(--text-secondary); margin: 4px 0;"><%= record.reason %></p>
                            <span style="font-size: 0.75rem; color: var(--text-muted);">
                                Посадил: <%= record.jailed_by %> • 
                                <%= record.jail_start ? new Date(record.jail_start).toLocaleDateString('ru-RU') : '—' %>
                            </span>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/theme.js"></script>
</body>
</html>

<%
function getTimeRemaining(dateStr) {
    if (!dateStr) return '—';
    var diff = new Date(dateStr) - new Date();
    if (diff <= 0) return 'истекло';
    var days = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins = Math.floor((diff % 3600000) / 60000);
    if (days > 0) return days + ' дн ' + hours + ' ч';
    if (hours > 0) return hours + ' ч ' + mins + ' м';
    return mins + ' мин';
}

function formatDuration(minutes) {
    if (!minutes || minutes <= 0) return '0 мин';
    var days = Math.floor(minutes / 1440);
    var hours = Math.floor((minutes % 1440) / 60);
    var mins = minutes % 60;
    var parts = [];
    if (days > 0) parts.push(days + ' дн');
    if (hours > 0) parts.push(hours + ' ч');
    if (mins > 0) parts.push(mins + ' мин');
    return parts.join(' ') || '0 мин';
}
%>